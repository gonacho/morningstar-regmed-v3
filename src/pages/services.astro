---
import BaseLayout from '@/layouts/BaseLayout.astro';

const services = [
  {
    title: 'Regulatory Strategy',
    description: 'Placeholder — content coming in Phase 2.',
  },
  {
    title: '510(k) & PMA Submissions',
    description: 'Placeholder — content coming in Phase 2.',
  },
  {
    title: 'Clinical Evaluation',
    description: 'Placeholder — content coming in Phase 2.',
  },
  {
    title: 'EU MDR / IVDR Compliance',
    description: 'Placeholder — content coming in Phase 2.',
  },
  {
    title: 'Post-Market Surveillance',
    description: 'Placeholder — content coming in Phase 2.',
  },
  {
    title: 'Quality Systems (QMS)',
    description: 'Placeholder — content coming in Phase 2.',
  },
];
---

<BaseLayout title="Services" description="Morningstar RegMed regulatory and medical affairs services for life sciences.">
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Our Services</h1>
      <p class="text-xl text-gray-600">Placeholder — content coming in Phase 2.</p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(({ title, description }) => (
          <div class="p-6 rounded-xl border border-gray-200 hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-lg text-brand-navy mb-2">{title}</h3>
            <p class="text-gray-500 text-sm">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-light py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Not sure where to start?</h2>
      <p class="text-gray-600 mb-6">Placeholder — content coming in Phase 2.</p>
      <a href="/contact" class="px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
