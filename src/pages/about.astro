---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about Morningstar RegMed's team and mission.">
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">About Us</h1>
      <p class="text-xl text-gray-600">Placeholder — content coming in Phase 2.</p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto prose prose-lg">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Our Mission</h2>
      <p class="text-gray-600">Placeholder — content coming in Phase 2.</p>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-10 text-center">Our Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[1, 2, 3].map((i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="w-16 h-16 bg-brand-light rounded-full mb-4" />
            <h3 class="font-semibold text-brand-navy">Team Member {i}</h3>
            <p class="text-gray-500 text-sm mt-1">Placeholder — content coming in Phase 2.</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
