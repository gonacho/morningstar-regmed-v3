---
const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="font-bold text-lg mb-3">Morning Star</h3>
        <p class="text-blue-200 text-sm leading-relaxed">
          Neuropathy & Pain Treatment Center serving St. Peters, MO and the greater St. Louis region.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wide mb-3 text-blue-300">Services</h4>
        <ul class="space-y-2">
          {[
            { href: '/neuropathy-treatment', label: 'Neuropathy Treatment' },
            { href: '/regenerative-therapy', label: 'Regenerative Therapy' },
            { href: '/platelet-rich-plasma-therapy', label: 'PRP Therapy' },
            { href: '/hyaluronic-acid-injections', label: 'HA Injections' },
            { href: '/medical-weight-loss', label: 'Medical Weight Loss' },
            { href: '/neuromodulation-technique', label: 'Neuromodulation' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-blue-200 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Conditions -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wide mb-3 text-blue-300">Conditions</h4>
        <ul class="space-y-2">
          {[
            { href: '/neuropathy', label: 'Neuropathy' },
            { href: '/back-pain', label: 'Back Pain' },
            { href: '/knee-pain', label: 'Knee Pain' },
            { href: '/neck-pain', label: 'Neck Pain' },
            { href: '/joint-pain', label: 'Joint Pain' },
            { href: '/sciatica-relief', label: 'Sciatica' },
            { href: '/chronic-pain-management', label: 'Chronic Pain' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-blue-200 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wide mb-3 text-blue-300">Contact</h4>
        <ul class="space-y-3 text-blue-200 text-sm">
          <li>
            <a href="tel:+16362440124" class="hover:text-white transition-colors">(636) 244-0124</a>
          </li>
          <li>4710 Mexico Rd, Suite C<br />St. Peters, MO 63376</li>
          <li>
            <a href="/schedule-appointment" class="hover:text-white transition-colors">Schedule Appointment →</a>
          </li>
        </ul>
        <div class="flex gap-4 mt-4">
          <a href="/privacy-policy" class="text-blue-300 hover:text-white text-xs transition-colors">Privacy Policy</a>
          <a href="/terms-service" class="text-blue-300 hover:text-white text-xs transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>

    <div class="border-t border-blue-800 mt-10 pt-6 text-center text-blue-300 text-xs">
      &copy; {year} Morning Star Neuropathy & Pain Treatment Center. All rights reserved.
    </div>
  </div>
</footer>
