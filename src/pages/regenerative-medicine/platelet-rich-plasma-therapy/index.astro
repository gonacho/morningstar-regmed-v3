---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TherapeuticProcedureSchema from '@/components/schemas/TherapeuticProcedureSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Platelet Rich Plasma Therapy in St. Peters, MO | Morning Star';
const description =
  'PRP therapy at Morning Star in St. Peters, MO uses your own platelets to accelerate healing. Non-surgical joint and tissue repair. Book your session.';

const faqs = [
  {
    question: 'How does PRP therapy work?',
    answer:
      'PRP therapy begins with a simple blood draw from your arm. The blood is then placed in a centrifuge to separate and concentrate the platelets. This platelet-rich plasma, packed with growth factors, is injected directly into the injured or damaged area, stimulating your body\'s natural healing response and accelerating tissue repair.',
  },
  {
    question: 'What conditions does PRP therapy treat?',
    answer:
      'PRP is effective for a range of musculoskeletal conditions including osteoarthritis, tendon injuries, ligament sprains, rotator cuff tears, and soft tissue damage. It is also used to support healing after certain procedures. Our team will evaluate your condition to determine if PRP is the most appropriate option.',
  },
  {
    question: 'How long does a PRP session take?',
    answer:
      'A typical PRP session takes approximately 45 minutes to one hour from start to finish. This includes the blood draw, processing time in the centrifuge, and the injection itself. Most patients are able to return to their normal routine the same day.',
  },
  {
    question: 'Is PRP therapy painful?',
    answer:
      'Most patients experience minimal discomfort during PRP therapy. A topical numbing cream is applied to the treatment area before the injection to reduce any pain. Some patients report mild soreness at the injection site for a day or two afterward, which typically resolves on its own.',
  },
  {
    question: 'How many PRP sessions will I need?',
    answer:
      'The number of sessions varies depending on the severity of your condition and your body\'s response to treatment. Many patients see significant improvement after 1 to 3 sessions spaced several weeks apart. Our team will create a personalized treatment plan based on your specific needs and progress.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalWebPage',
      name: title,
      description: description,
      url: 'https://morningstarregmed.com/regenerative-medicine/platelet-rich-plasma-therapy/',
      isPartOf: {
        '@type': 'WebSite',
        name: 'Morning Star Neuropathy & Pain Treatment Center',
        url: 'https://morningstarregmed.com/',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://morningstarregmed.com/' },
          { '@type': 'ListItem', position: 2, name: 'Regenerative Medicine', item: 'https://morningstarregmed.com/regenerative-medicine/' },
          { '@type': 'ListItem', position: 3, name: 'Platelet-Rich Plasma Therapy' },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ question, answer }) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: { '@type': 'Answer', text: answer },
      })),
    },
  ],
});
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <TherapeuticProcedureSchema
      id="service-platelet-rich-plasma-therapy"
      name="Platelet Rich Plasma Therapy"
      description="PRP therapy using your own platelets to accelerate joint healing and soft tissue repair without surgery."
      url="https://morningstarregmed.com/regenerative-medicine/platelet-rich-plasma-therapy/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      indication={["condition-knee-pain","condition-back-pain","condition-joint-pain"]}
      bodyLocation={["joints","shoulders","knees"]}
      reviews={[
  {
    "author": "John Brantley",
    "datePublished": "2024-01-01",
    "reviewBody": "I have had two separate rounds of treatment done with the team at Morningstar. First, I had hyaluronic acid gel injections done on my knee. My pain went from an 8/10 to at most a 2/10. Great success if you ask me! Kay's bedside manner is absolutely wonderful and the admin staff made me feel welcomed and stress-free. After I finished with my knee, I did PRP treatments to both of my shoulders. My shoulders have been very weak and causing me a lot of pain due to what I do for a living, and this has been the only thing to help so far. Definitely helped me avoid shoulder surgery and now my pain is maybe a 2/10 on a bad day! These people work absolute miracles for non-invasive pain management options, and I recommend them hands down to anyone looking for relief! 5 stars!",
    "ratingValue": "5"
  }
]}
      aggregateRating={{"ratingValue":"5","reviewCount":"1"}}
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/regenerative-medicine/platelet-rich-plasma-therapy/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#service-platelet-rich-plasma-therapy"
      aspect="Treatment"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Regenerative Medicine","url":"https://morningstarregmed.com/regenerative-medicine/"},{"name":"PRP Therapy","url":"https://morningstarregmed.com/regenerative-medicine/platelet-rich-plasma-therapy/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-muted" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-primary">Home</a></li>
      <li>/</li>
      <li><a href="/regenerative-medicine/" class="hover:text-primary">Regenerative Medicine</a></li>
      <li>/</li>
      <li class="text-dark font-medium">PRP Therapy</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="bg-bg-warm py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-6">
        Platelet-Rich Plasma (PRP) Therapy in St. Peters, MO
      </h1>
      <p class="text-xl text-body max-w-2xl">
        Use your body's own concentrated platelets to accelerate healing, reduce pain, and repair damaged tissue, without surgery.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 btn-primary inline-flex"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">What Is PRP Therapy?</h2>
      <p class="text-body leading-relaxed mb-4">
        <b>Platelet-rich plasma (PRP) therapy</b> is a regenerative treatment that uses concentrated platelets from your own blood to promote healing. Platelets contain growth factors that play a critical role in tissue repair, making PRP a natural and effective option for chronic joint conditions, soft tissue injuries, and osteoarthritis.
      </p>
      <p class="text-body leading-relaxed mb-4">
        At <b>Morning Star Neuropathy &amp; Pain Treatment Center</b>, PRP sessions are performed in-office and typically take 45 minutes to an hour. The procedure involves a simple blood draw, processing in a centrifuge, and a targeted injection into the affected area. A numbing cream is applied beforehand to minimize any discomfort.
      </p>
      <p class="text-body leading-relaxed">
        PRP therapy is one of several <a href="/regenerative-medicine/" class="text-primary underline hover:text-primary-dark">regenerative medicine</a> treatments we offer at our St. Peters clinic. Depending on your condition, our team may also recommend <a href="/regenerative-medicine/regenerative-therapy/" class="text-primary underline hover:text-primary-dark">exosome-based regenerative therapy</a> or <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary underline hover:text-primary-dark">hyaluronic acid injections</a> as part of your recovery plan.
      </p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-8">How PRP Therapy Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">1. Blood Draw</div>
          <p class="text-body text-sm leading-relaxed">
            A small sample of blood is drawn from your arm, similar to a routine blood test. The process is quick and straightforward.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">2. Platelet Concentration</div>
          <p class="text-body text-sm leading-relaxed">
            Your blood is placed in a centrifuge that separates the platelets and concentrates them into a small volume of plasma rich in growth factors.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">3. Targeted Injection</div>
          <p class="text-body text-sm leading-relaxed">
            The concentrated PRP is injected directly into the damaged tissue or joint, where the growth factors stimulate your body's natural repair process.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Conditions Treated -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Conditions Treated with PRP</h2>
      <p class="text-body leading-relaxed mb-6">
        PRP therapy is effective for musculoskeletal conditions where the body's natural healing response needs a boost. Patients come to our St. Peters office for PRP treatment of:
      </p>
      <ul class="grid md:grid-cols-2 gap-3 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/knee-pain/" class="text-primary underline hover:text-primary-dark">Knee pain</a> from osteoarthritis or sports injuries</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/back-pain/" class="text-primary underline hover:text-primary-dark">Back pain</a> related to disc or tissue damage</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/joint-pain/" class="text-primary underline hover:text-primary-dark">Joint pain</a> in shoulders, hips, and wrists</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Rotator cuff tears and tendon injuries</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Ligament sprains and soft tissue damage</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Chronic inflammation that has not responded to other treatments</span>
        </li>
      </ul>
      <p class="text-body leading-relaxed">
        Our clinical team reviews your imaging and medical history before recommending PRP. If a different approach would serve you better, we will let you know.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-8">Benefits of PRP Therapy</h2>
      <ul class="grid md:grid-cols-2 gap-4">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Uses your own blood with no synthetic materials</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Stimulates natural tissue repair and healing</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Non-surgical with minimal downtime</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Effective for osteoarthritis and joint conditions</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Minimal pain with topical numbing cream</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Sessions completed in under one hour</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-8">What Our Patients Say</h2>
      <blockquote class="bg-white rounded-2xl p-8 border border-border shadow-sm">
        <p class="text-body leading-relaxed italic mb-4">
          "I have had two separate rounds of treatment done with the team at Morningstar. First, I had hyaluronic acid gel injections done on my knee. My pain went from an 8/10 to at most a 2/10. Great success if you ask me! Kay's bedside manner is absolutely wonderful and the admin staff made me feel welcomed and stress-free. After I finished with my knee, I did PRP treatments to both of my shoulders. My shoulders have been very weak and causing me a lot of pain due to what I do for a living, and this has been the only thing to help so far. Definitely helped me avoid shoulder surgery and now my pain is maybe a 2/10 on a bad day! These people work absolute miracles for non-invasive pain management options, and I recommend them hands down to anyone looking for relief! 5 stars!"
        </p>
        <footer class="text-dark font-semibold">
          John B.
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Why Morning Star -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Why Choose Morning Star for PRP Therapy?</h2>
      <p class="text-body leading-relaxed mb-4">
        Morning Star Neuropathy &amp; Pain Treatment Center brings a personalized approach to every PRP session. We do not rush patients through a standard protocol. Instead, our team takes time to understand your condition, explain the process, and build a treatment plan tailored to your body's needs.
      </p>
      <p class="text-body leading-relaxed mb-4">
        Our office at 4710 Mexico Rd Suite C in St. Peters, MO is equipped for same-day PRP treatments. From blood draw to injection, the entire session happens in one visit. Most patients drive themselves home and return to their normal routine the same day.
      </p>
      <p class="text-body leading-relaxed">
        If you are exploring regenerative options, we encourage you to learn about our full range of treatments. <a href="/regenerative-medicine/regenerative-therapy/" class="text-primary underline hover:text-primary-dark">Exosome-based regenerative therapy</a> and <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary underline hover:text-primary-dark">hyaluronic acid injections</a> are also available at our clinic and may be recommended depending on your diagnosis.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-2xl p-6 border border-border">
            <dt class="font-semibold text-dark mb-2">{question}</dt>
            <dd class="text-body text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Heal Naturally with PRP Therapy</h2>
      <p class="text-white/70 mb-8">
        Contact Morning Star at <a href="tel:+16362440124" class="text-white underline hover:text-blue-100">(636) 244-0124</a> to learn how platelet-rich plasma therapy can help you recover from joint pain and soft tissue injuries.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white hover:text-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
