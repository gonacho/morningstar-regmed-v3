---
const currentPath = Astro.url.pathname;

const painServices = [
  { href: '/pain-management/neuropathy-treatment/', label: 'Neuropathy Treatment' },
  { href: '/pain-management/chronic-pain-management/', label: 'Chronic Pain Management' },
  { href: '/pain-management/neuromodulation-technique/', label: 'Neuromodulation Technique' },
];

const regenServices = [
  { href: '/regenerative-medicine/regenerative-therapy/', label: 'Regenerative Therapy' },
  { href: '/regenerative-medicine/platelet-rich-plasma-therapy/', label: 'PRP Therapy' },
  { href: '/regenerative-medicine/hyaluronic-acid-injections/', label: 'Hyaluronic Acid Injections' },
];

const conditions = [
  { href: '/conditions/neuropathy/', label: 'Neuropathy' },
  { href: '/conditions/knee-pain/', label: 'Knee Pain' },
  { href: '/conditions/back-pain/', label: 'Back Pain' },
  { href: '/conditions/neck-pain/', label: 'Neck Pain' },
  { href: '/conditions/joint-pain/', label: 'Joint Pain' },
  { href: '/conditions/sciatica/', label: 'Sciatica' },
];
---

<header id="site-header" class="bg-white shadow-sm sticky top-0 z-50 transition-shadow duration-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <span class="font-heading font-700 text-xl text-dark leading-tight">
          Morning Star
          <span class="block text-xs font-sans font-400 text-muted tracking-wide">Neuropathy & Pain</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-sans font-500 text-body hover:text-primary rounded-md transition-colors group-hover:text-primary"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <!-- Mega menu -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 w-[640px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-2xl shadow-lg border border-border p-6 grid grid-cols-3 gap-6">
              <!-- Pain Management -->
              <div>
                <a href="/pain-management/" class="block text-xs font-heading font-600 text-primary uppercase tracking-widest mb-3 hover:underline">
                  Pain Management
                </a>
                <ul class="space-y-2">
                  {painServices.map(({ href, label }) => (
                    <li>
                      <a href={href} class="text-sm text-body hover:text-primary hover:font-500 transition-colors block py-0.5">
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Regenerative Medicine -->
              <div>
                <a href="/regenerative-medicine/" class="block text-xs font-heading font-600 text-primary uppercase tracking-widest mb-3 hover:underline">
                  Regenerative Medicine
                </a>
                <ul class="space-y-2">
                  {regenServices.map(({ href, label }) => (
                    <li>
                      <a href={href} class="text-sm text-body hover:text-primary hover:font-500 transition-colors block py-0.5">
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Weight Loss -->
              <div>
                <span class="block text-xs font-heading font-600 text-primary uppercase tracking-widest mb-3">
                  Weight Loss
                </span>
                <a href="/medical-weight-loss/" class="text-sm text-body hover:text-primary hover:font-500 transition-colors block py-0.5">
                  Medical Weight Loss
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Conditions dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-sans font-500 text-body hover:text-primary rounded-md transition-colors group-hover:text-primary"
            aria-haspopup="true"
          >
            Conditions
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-2xl shadow-lg border border-border py-2">
              {conditions.map(({ href, label }) => (
                <a href={href} class="block px-4 py-2 text-sm text-body hover:bg-bg-warm hover:text-primary transition-colors">
                  {label}
                </a>
              ))}
              <div class="border-t border-border mt-1 pt-1">
                <a href="/conditions/" class="block px-4 py-2 text-sm font-500 text-primary hover:bg-bg-warm transition-colors">
                  View All Conditions →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Static links -->
        <a href="/about/" class:list={['px-3 py-2 text-sm font-sans font-500 rounded-md transition-colors', currentPath.startsWith('/about') ? 'text-primary' : 'text-body hover:text-primary']}>
          About
        </a>
        <a href="/contact/" class:list={['px-3 py-2 text-sm font-sans font-500 rounded-md transition-colors', currentPath.startsWith('/contact') ? 'text-primary' : 'text-body hover:text-primary']}>
          Contact
        </a>
        <a href="/blog/" class:list={['px-3 py-2 text-sm font-sans font-500 rounded-md transition-colors', currentPath.startsWith('/blog') ? 'text-primary' : 'text-body hover:text-primary']}>
          Blog
        </a>

        <!-- Phone -->
        <a href="tel:+16362440124" class="ml-1 text-sm font-sans font-500 text-body hover:text-primary transition-colors whitespace-nowrap hidden xl:block">
          (636) 244-0124
        </a>

        <!-- CTA -->
        <a
          href="/schedule-appointment/"
          class="ml-3 inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-600 text-sm px-5 py-2.5 rounded-full transition-all duration-200 shadow-sm hover:shadow-md whitespace-nowrap"
        >
          Book Free Consultation
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-body hover:text-primary"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" id="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </nav>
</header>

<!-- Mobile menu — full-screen dark slide-in panel (outside header for full-screen positioning) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-dark transform -translate-x-full transition-transform duration-300 ease-in-out lg:hidden overflow-y-auto"
  aria-hidden="true"
>
  <!-- Header row inside panel -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-white/10">
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-xl bg-accent flex items-center justify-center">
        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 3a1 1 0 110 2 1 1 0 010-2zm-1 4h2v5H9V9z"/></svg>
      </div>
      <span class="font-heading font-semibold text-white text-base">Morning Star</span>
    </a>
    <button id="mobile-close-btn" class="p-2 text-white/70 hover:text-white" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div class="px-6 py-8 space-y-8">
    <div>
      <p class="text-accent text-xs font-medium uppercase tracking-widest mb-3">Pain Management</p>
      <ul class="space-y-3">
        {painServices.map(({ href, label }) => (
          <li><a href={href} class="text-white/80 hover:text-white font-sans text-base transition-colors block">{label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="text-accent text-xs font-medium uppercase tracking-widest mb-3">Regenerative Medicine</p>
      <ul class="space-y-3">
        {regenServices.map(({ href, label }) => (
          <li><a href={href} class="text-white/80 hover:text-white font-sans text-base transition-colors block">{label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="text-accent text-xs font-medium uppercase tracking-widest mb-3">Conditions</p>
      <ul class="space-y-3">
        {conditions.map(({ href, label }) => (
          <li><a href={href} class="text-white/80 hover:text-white font-sans text-base transition-colors block">{label}</a></li>
        ))}
        <li><a href="/conditions/" class="text-accent hover:text-white font-sans text-base transition-colors">All Conditions →</a></li>
      </ul>
    </div>
    <div class="border-t border-white/10 pt-6 space-y-3">
      <a href="/about/" class="block text-white/80 hover:text-white font-sans text-base transition-colors">About</a>
      <a href="/contact/" class="block text-white/80 hover:text-white font-sans text-base transition-colors">Contact</a>
      <a href="/blog/" class="block text-white/80 hover:text-white font-sans text-base transition-colors">Blog</a>
      <a href="/medical-weight-loss/" class="block text-white/80 hover:text-white font-sans text-base transition-colors">Medical Weight Loss</a>
    </div>
    <div class="pt-2 space-y-3">
      <a href="/schedule-appointment/" class="block w-full text-center py-3.5 bg-accent hover:bg-accent-dark text-white font-heading font-semibold rounded-full transition-colors">
        Book Free Consultation
      </a>
      <a href="tel:+16362440124" class="block w-full text-center py-3.5 border-2 border-white/20 text-white font-heading font-semibold rounded-full hover:border-white/40 transition-colors">
        (636) 244-0124
      </a>
    </div>
  </div>
</div>
<div id="mobile-backdrop" class="fixed inset-0 z-[55] bg-black/50 hidden lg:hidden"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const backdrop = document.getElementById('mobile-backdrop');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function openMenu() {
    menu?.classList.remove('-translate-x-full');
    menu?.setAttribute('aria-hidden', 'false');
    backdrop?.classList.remove('hidden');
    hamburger?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('-translate-x-full');
    menu?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.add('hidden');
    hamburger?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>
