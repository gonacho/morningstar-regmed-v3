---
import BaseLayout from '@/layouts/BaseLayout.astro';

export interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  metaDescription: string;
  h1: string;
  heroText: string;
  faqs?: FAQ[];
  /** Optional pre-serialised JSON-LD to pass through to BaseLayout */
  jsonLd?: string;
}

const { title, metaDescription, h1, heroText, faqs = [], jsonLd } = Astro.props;

// Build FAQ schema if FAQs are provided
const faqSchema =
  faqs.length > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map(({ question, answer }) => ({
          '@type': 'Question',
          name: question,
          acceptedAnswer: { '@type': 'Answer', text: answer },
        })),
      })
    : undefined;

const resolvedJsonLd = jsonLd ?? faqSchema;
---

<BaseLayout title={title} description={metaDescription} jsonLd={resolvedJsonLd}>
  <!-- Hero -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">{h1}</h1>
      <p class="text-xl text-gray-600">{heroText}</p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Body content slot -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto prose prose-lg prose-headings:text-brand-navy prose-a:text-brand-blue">
      <slot />
    </div>
  </section>

  <!-- FAQs -->
  {faqs.length > 0 && (
    <section class="bg-gray-50 py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
        <dl class="space-y-6">
          {faqs.map(({ question, answer }) => (
            <div class="bg-white rounded-xl p-6 border border-gray-200">
              <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
              <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-blue-200 mb-8">
        Contact Morningstar RegMed today to discuss how we can help you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
