---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OfferCatalogSchema from '@/components/schemas/OfferCatalogSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';

const SITE_URL = 'https://morningstarregmed.com';
const pageUrl = `${SITE_URL}/regenerative-medicine/`;
const title = 'Alternative Medicine Practitioner in St. Peters, MO | Morning Star';
const description =
  'Regenerative medicine in St. Peters, MO. PRP therapy, exosome therapy, and hyaluronic acid injections. Advanced non-surgical healing at Morning Star.';

const services = [
  {
    name: 'Regenerative Therapy',
    url: `${SITE_URL}/regenerative-medicine/regenerative-therapy/`,
    description: 'Exosome-based treatments that reduce inflammation and support cellular tissue repair.',
    serviceId: 'service-regenerative-therapy',
  },
  {
    name: 'Platelet Rich Plasma Therapy',
    url: `${SITE_URL}/regenerative-medicine/platelet-rich-plasma-therapy/`,
    description: 'PRP injections using your own platelets to accelerate joint and soft tissue healing.',
    serviceId: 'service-platelet-rich-plasma-therapy',
  },
  {
    name: 'Hyaluronic Acid Injections',
    url: `${SITE_URL}/regenerative-medicine/hyaluronic-acid-injections/`,
    description: 'Minimally invasive joint lubrication injections for improved mobility and pain relief.',
    serviceId: 'service-hyaluronic-acid-injections',
  },
];
const breadcrumbs = [
  { name: 'Home', url: SITE_URL },
  { name: 'Regenerative Medicine', url: pageUrl },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <OfferCatalogSchema
      id="catalog-regenerative-medicine"
      name="Regenerative Medicine Services"
      description={description}
      url={pageUrl}
      services={services}
    />
    <MedicalWebPageSchema
      url={pageUrl}
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId={`${SITE_URL}/#catalog-regenerative-medicine`}
    />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>
  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Alternative Medicine Practitioner in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Your body already knows how to heal. It just needs the right support. Morning Star uses regenerative therapies that work with your biology, not against it, to reduce inflammation, repair damaged tissue, and restore joint function without surgery.
      </p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Regenerative Medicine at Morning Star</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Regenerative medicine represents a shift away from treatments that only mask pain. Instead of covering up symptoms with medication, these therapies stimulate your body's natural repair mechanisms at the cellular level. Damaged cartilage, inflamed tendons, and deteriorating joints respond to treatments that deliver concentrated growth factors and signaling molecules directly to the injury site.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Our <a href="/" class="text-brand-blue hover:underline">St. Peters clinic</a> offers three targeted regenerative treatments, each suited to different conditions and stages of tissue damage. Every patient receives a thorough evaluation before we recommend which approach, or combination of approaches, fits their situation.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Regenerative Medicine Services</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/regenerative-medicine/regenerative-therapy/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Regenerative Therapy (Exosomes)</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Exosome-based treatments that deliver growth factors directly to damaged tissue, reducing inflammation and promoting cellular repair for long-term healing.
          </p>
        </a>
        <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Platelet Rich Plasma Therapy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            PRP injections concentrate your own platelets to accelerate healing in joints and soft tissues. Sessions take under an hour with minimal downtime.
          </p>
        </a>
        <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Hyaluronic Acid Injections</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Restore natural joint lubrication with minimally invasive HA injections. Relief typically lasts 4 to 6 months with results building over several weeks.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Conditions -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Conditions That Respond to Regenerative Treatment</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Patients in St. Peters and the greater St. Louis area seek regenerative care for:
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/conditions/knee-pain/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Knee Pain</span>
        </a>
        <a href="/conditions/joint-pain/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Joint Pain</span>
        </a>
        <a href="/conditions/back-pain/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Back Pain</span>
        </a>
        <a href="/conditions/neuropathy/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Neuropathy</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Morning Star -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Why Patients Choose Morning Star for Regenerative Care</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Regenerative medicine is only as effective as the clinical team delivering it. At Morning Star, every treatment protocol is customized to the individual patient. We do not offer cookie-cutter injection packages. We evaluate, diagnose, and build a plan specific to your tissue damage, pain levels, and recovery timeline.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Our St. Peters, MO clinic is conveniently located on Mexico Rd, near Mid Rivers Mall, with access from I-70 and Highway 94. We serve patients from across St. Charles County, including O'Fallon, Wentzville, Lake St. Louis, and the broader St. Louis metro area.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Discover Regenerative Medicine in St. Peters</h2>
      <p class="text-blue-200 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or schedule online to find out which regenerative therapy is right for your condition.
      </p>
      <a href="/schedule-appointment" class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Schedule Your Consultation
      </a>
    </div>
  </section>
</BaseLayout>
