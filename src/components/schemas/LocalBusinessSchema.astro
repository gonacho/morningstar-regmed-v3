  '@context': 'https://schema.org',
  '@type': ['MedicalClinic', 'LocalBusiness'],
  '@id': `${SITE_URL}/#localbusiness`,
  name: 'Morning Star Neuropathy & Pain Treatment Center',
  url: SITE_URL,
  telephone: '+16362440124',
  priceRange: '$$',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '08:00',
      closes: '17:00',
    },
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '4710 Mexico Rd Suite C',
    addressLocality: 'St. Peters',
    addressRegion: 'MO',
    postalCode: '63376',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 38.7696,
    longitude: -90.6268,
  },
  areaServed: {
