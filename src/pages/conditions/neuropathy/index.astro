---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalConditionSchema from '@/components/schemas/MedicalConditionSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Neuropathy Treatment in St. Peters, MO | Morning Star';
const description =
  'Learn about neuropathy causes, symptoms, and treatment options at Morning Star in St. Peters, MO. Expert care for nerve damage and neuropathic pain.';

const faqs = [
  {
    question: 'What is the main cause of neuropathy?',
    answer:
      'Diabetes is the most common cause of peripheral neuropathy, responsible for roughly 60 percent of all cases. Persistently high blood sugar damages the small blood vessels that supply nerves, particularly in the hands and feet. Other common causes include infections, traumatic injuries, autoimmune disorders, vitamin deficiencies (especially B12), and prolonged exposure to toxins or certain medications.',
  },
  {
    question: 'Can neuropathy be cured?',
    answer:
      'In most cases, neuropathy is managed rather than cured. Treatment focuses on addressing the underlying cause, relieving symptoms, and preventing further nerve damage. When the root cause is correctable (such as a vitamin deficiency or medication side effect), nerve function may partially or fully recover. Many patients at Morning Star experience meaningful improvement in pain levels, sensation, and mobility with a consistent treatment plan.',
  },
  {
    question: 'What makes neuropathy worse?',
    answer:
      'Several factors can accelerate nerve damage and worsen symptoms. Poor blood sugar control is the most significant aggravator for diabetic neuropathy. Smoking restricts blood flow to the nerves, alcohol is directly toxic to nerve tissue, and prolonged pressure on specific areas (such as sitting or standing in one position) compounds existing damage. Maintaining a healthy lifestyle and managing underlying conditions is essential to slowing progression.',
  },
  {
    question: 'Can sitting too long cause nerve damage?',
    answer:
      'Yes, prolonged sitting can contribute to nerve damage through compression. Sitting for extended periods puts pressure on nerves in the legs and lower back, which can lead to numbness, tingling, and pain. This is especially problematic for people who already have neuropathy. Taking regular breaks to stand, stretch, and walk is important for maintaining nerve health and circulation.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalConditionSchema
      id="condition-neuropathy"
      name="Peripheral Neuropathy"
      description="Peripheral neuropathy causes nerve damage leading to numbness, tingling, and pain, most often in the feet and hands. Learn about causes, symptoms, and treatment options in St. Peters, MO."
      url="https://morningstarregmed.com/conditions/neuropathy/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      possibleTreatments={["service-neuropathy-treatment","service-neuromodulation-technique","service-regenerative-therapy"]}
      causes={["Diabetes mellitus","Autoimmune disorders","Nutritional deficiencies","Certain medications","Physical trauma"]}
      signOrSymptom={["Numbness in feet and hands","Burning sensation","Tingling","Muscle weakness","Balance problems"]}
      associatedAnatomy="Peripheral nervous system"
      riskFactor={["Diabetes","Alcohol use disorder","Vitamin B12 deficiency","Chemotherapy"]}
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/conditions/neuropathy/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#condition-neuropathy"
      aspect="Symptom"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Conditions","url":"https://morningstarregmed.com/conditions/"},{"name":"Neuropathy","url":"https://morningstarregmed.com/conditions/neuropathy/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Hero -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Neuropathy Treatment in St.&nbsp;Peters, MO</h1>
      <p class="text-xl text-gray-600">
        Neuropathy affects millions of Americans every year, causing tingling, numbness, weakness, and
        pain that can disrupt sleep, work, and everyday activities. At Morning Star Neuropathy &amp; Pain
        Treatment Center in St.&nbsp;Peters, MO, we help patients understand their condition and find a
        clear path toward lasting relief.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- What Is Neuropathy -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">What Is Neuropathy?</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        <strong>Neuropathy</strong> (also called <strong>peripheral neuropathy</strong>) is a condition
        that develops when the peripheral nerves become damaged. These nerves form a vast communication
        network between the brain, spinal cord, and the rest of the body. When they are compromised, the
        signals they carry become distorted or interrupted entirely.
      </p>
      <p class="text-gray-600 mb-4 leading-relaxed">
        The result is a range of symptoms that typically begin in the hands and feet: tingling, burning
        sensations, sharp pain, numbness, and muscle weakness. Over time, untreated neuropathy can lead
        to balance problems, difficulty walking, and a significant decline in quality of life.
      </p>
      <p class="text-gray-600 leading-relaxed">
        This page focuses on understanding the condition itself. For details on how we treat neuropathy
        at our St.&nbsp;Peters clinic, visit our
        <a href="/pain-management/neuropathy-treatment/" class="text-brand-blue underline hover:text-blue-700">neuropathy treatment</a> page.
      </p>
    </div>
  </section>

  <!-- Types of Neuropathy -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Types of Neuropathy</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Sensory Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Affects the nerves that carry sensations such as pain, temperature, and touch. Symptoms
            include tingling, numbness, and burning pain in the extremities.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Motor Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Damages the nerves that control muscle movement, leading to weakness, muscle wasting, and
            difficulty with coordination and balance.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Autonomic Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Affects involuntary body functions such as heart rate, blood pressure, digestion, and
            bladder control. This type can cause dizziness, digestive issues, and abnormal sweating.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Combination Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Many patients experience a mix of sensory, motor, and autonomic nerve damage simultaneously.
            A comprehensive evaluation is essential for building an effective treatment plan.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Common Causes of Neuropathy</h2>

      <h3 class="text-lg font-semibold text-brand-navy mb-2">Diabetes</h3>
      <p class="text-gray-600 mb-4 leading-relaxed">
        <strong>Diabetic neuropathy</strong> is the leading cause, responsible for roughly 60 percent
        of all peripheral neuropathy cases. High blood sugar levels gradually damage the small blood
        vessels that supply nerves, especially in the feet and lower legs.
      </p>

      <h3 class="text-lg font-semibold text-brand-navy mb-2">Infections</h3>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Lyme disease, shingles, hepatitis, and HIV can each trigger nerve inflammation and damage.
        Post-infectious neuropathy sometimes persists long after the initial illness resolves.
      </p>

      <h3 class="text-lg font-semibold text-brand-navy mb-2">Autoimmune Disorders</h3>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Conditions such as lupus, rheumatoid arthritis, and Guillain-Barr&eacute; syndrome cause the
        immune system to attack healthy nerve tissue, resulting in progressive damage.
      </p>

      <h3 class="text-lg font-semibold text-brand-navy mb-2">Toxins and Medications</h3>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Heavy metals, industrial chemicals, and certain chemotherapy drugs are known to damage
        peripheral nerves. Chronic alcohol use is also directly toxic to nerve tissue.
      </p>

      <h3 class="text-lg font-semibold text-brand-navy mb-2">Vitamin Deficiencies and Trauma</h3>
      <p class="text-gray-600 leading-relaxed">
        B-vitamin deficiencies (particularly B12) starve nerves of essential nutrients. Physical
        trauma from accidents, falls, or repetitive stress injuries can damage nerves at the site of
        impact.
      </p>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Symptoms of Neuropathy</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        <strong>Neuropathy symptoms</strong> vary depending on which nerves are affected, but commonly
        include:
      </p>
      <ul class="space-y-3 text-gray-600">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Tingling or a pins-and-needles sensation in hands and feet</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Numbness or reduced ability to feel pain or temperature changes</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Sharp, burning, or stabbing pain (often worse at night)</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Muscle weakness and loss of coordination</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Extreme sensitivity to touch, even light pressure</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Balance problems and difficulty walking</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Cramping or muscle twitching</li>
      </ul>
    </div>
  </section>

  <!-- Treatment Options at Morning Star -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Treatment Options at Morning Star</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Our team in St.&nbsp;Peters specializes in advanced, non-invasive approaches to neuropathy
        care. We focus on reducing pain, restoring function, and slowing disease progression through
        targeted therapies.
      </p>

      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Neuropathy Treatment Program</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Our specialized <a href="/pain-management/neuropathy-treatment/" class="text-brand-blue underline hover:text-blue-700">neuropathy treatment program</a>
            combines multiple modalities to address nerve damage at its source. This comprehensive
            protocol targets pain relief, improved circulation, and nerve regeneration.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Neuromodulation Technique</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Our <a href="/pain-management/neuromodulation-technique/" class="text-brand-blue underline hover:text-blue-700">neuromodulation technique</a>
            modifies nerve activity to reduce pain signals and restore more normal nerve function.
            This therapy is particularly effective for patients with chronic neuropathic pain.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Regenerative Therapy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Advanced <a href="/regenerative-medicine/regenerative-therapy/" class="text-brand-blue underline hover:text-blue-700">regenerative therapy</a>
            supports nerve repair and reduces inflammation at the cellular level, giving damaged
            nerves the biological resources they need to heal.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">What Our Patients Say</h2>
      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <p class="text-gray-600 leading-relaxed mb-3 italic">
            "I had neuropathy in my feet and now it's about gone with the treatment they're giving me and they do actually work. They know what they're doing this is a very good place if you have neuropathy. The treatments are helping very much so and I really love it's starting to help."
          </p>
          <p class="font-semibold text-brand-navy text-sm">Arthur Brewer</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <p class="text-gray-600 leading-relaxed mb-3 italic">
            "I found out I had neuropathy in my feet. I had no idea where to go. I Googled neuropathy places and came across Morningstar. I am so thankful I did! I felt welcome the 1st time I went there. When I first started treatments, they had to wheel me in from the car to the treatment room in a wheelchair. I have been going for about 2 months. I went from arriving in a wheelchair to walking with a cane! Marvelous improvement from not being able to walk at all. I owe all this to the wonderful staff of Morningstar! I love these people, Heather, Mandy, Rochelle, Brad and Ron. They are such caring people. Please give them a try if you need help with neuropathy."
          </p>
          <p class="font-semibold text-brand-navy text-sm">Brenda Landers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">When to Seek Help</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Early treatment is critical for neuropathy. The longer nerve damage goes unaddressed, the
        harder it becomes to manage symptoms and prevent further deterioration. You should seek
        professional care if you experience:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Persistent tingling or numbness that does not resolve on its own</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Pain that interferes with sleep, work, or daily activities</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Weakness in your hands or feet that affects grip or balance</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Symptoms that are gradually worsening over time</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> New symptoms appearing in additional areas of the body</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        At Morning Star, we provide thorough evaluations to identify the underlying cause of your
        neuropathy and develop a personalized care plan tailored to your needs. Call us at
        <a href="tel:+16362440124" class="text-brand-blue underline hover:text-blue-700">(636) 244-0124</a>
        to get started.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Take the First Step Toward Relief</h2>
      <p class="text-blue-200 mb-8">
        Do not let neuropathy control your life. Contact Morning Star Neuropathy &amp; Pain Treatment
        Center in St.&nbsp;Peters, MO today to schedule your consultation and begin your journey to
        better nerve health.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact-us/"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
