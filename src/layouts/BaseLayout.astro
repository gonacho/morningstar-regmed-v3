---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Serialised JSON-LD object(s) for structured data. Pass a string or leave
   *  undefined; the layout will inject it inside <script type="application/ld+json">. */
  jsonLd?: string;
}

const {
  title,
  description = 'Morning Star Neuropathy & Pain Treatment Center in St. Peters, MO — advanced neuropathy care, regenerative therapy, and pain management.',
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Morning Star</title>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <!-- JSON-LD slot: child pages may inject additional structured data here -->
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-full bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
