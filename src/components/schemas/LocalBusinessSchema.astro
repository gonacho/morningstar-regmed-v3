      '@type': 'GeoCoordinates',
      latitude: 38.7696,
      longitude: -90.6268,
    },
    geoRadius: '40234',
    containsPlace: [
      // Tier-2 landmarks
      {
        '@type': 'SportsFacility',
        name: "St. Peters Rec-Plex",
        sameAs: 'https://en.wikipedia.org/wiki/St._Peters,_Missouri',
      },
      {
        '@type': 'ShoppingCenter',
