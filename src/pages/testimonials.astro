---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Placeholder reviews — SEO Writer / CMS will populate in Phase 2.
const reviews = [
  {
    name: 'Patient A',
    rating: 5,
    text: 'Placeholder — content coming in Phase 2.',
  },
  {
    name: 'Patient B',
    rating: 5,
    text: 'Placeholder — content coming in Phase 2.',
  },
  {
    name: 'Patient C',
    rating: 5,
    text: 'Placeholder — content coming in Phase 2.',
  },
];

// AggregateRating schema — update ratingValue/reviewCount with real data in Phase 2
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: 'Morningstar RegMed',
  url: 'https://morningstarregmed.com',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: reviews.length.toString(),
    bestRating: '5',
    worstRating: '1',
  },
  review: reviews.map(({ name, rating, text }) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name },
    reviewRating: { '@type': 'Rating', ratingValue: rating.toString(), bestRating: '5' },
    reviewBody: text,
  })),
});
---

<BaseLayout
  title="Patient Testimonials"
  description="Read what patients say about their experience with Morningstar RegMed's regenerative medicine and pain management treatments."
  jsonLd={jsonLd}
>
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Patient Testimonials</h1>
      <p class="text-xl text-gray-600">
        Real stories from patients who found relief through our regenerative medicine programs.
      </p>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map(({ name, rating, text }) => (
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-1 mb-3" aria-label={`${rating} out of 5 stars`}>
            {Array.from({ length: rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.449a1 1 0 00-.364 1.118l1.286 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.449a1 1 0 00-1.176 0l-3.37 2.449c-.784.57-1.838-.197-1.539-1.118l1.285-3.957a1 1 0 00-.364-1.118L2.063 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69L9.05 2.927z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-gray-600 text-sm mb-4">"{text}"</blockquote>
          <p class="font-semibold text-brand-navy text-sm">— {name}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Join our patients on the path to relief</h2>
      <p class="text-blue-200 mb-8">
        Schedule a consultation to discuss your treatment options.
      </p>
      <a
        href="/schedule-appointment"
        class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</BaseLayout>
