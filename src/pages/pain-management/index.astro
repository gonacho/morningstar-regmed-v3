---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OfferCatalogSchema from '@/components/schemas/OfferCatalogSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';

const SITE_URL = 'https://morningstarregmed.com';
const pageUrl = `${SITE_URL}/pain-management/`;
const title = 'Pain Control Clinic in St. Peters, MO | Morning Star';
const description =
  'Expert pain management in St. Peters, MO. Neuropathy treatment, chronic pain management, and neuromodulation therapy. Non-surgical relief at Morning Star.';

const services = [
  {
    name: 'Neuropathy Treatment',
    url: `${SITE_URL}/pain-management/neuropathy-treatment/`,
    description: 'Customized plans to restore peripheral nerve health and relieve neuropathic pain.',
    serviceId: 'service-neuropathy-treatment',
  },
  {
    name: 'Chronic Pain Management',
    url: `${SITE_URL}/pain-management/chronic-pain-management/`,
    description: 'Personalized pain management combining regenerative, neuromodulation, and lifestyle therapies.',
    serviceId: 'service-chronic-pain-management',
  },
  {
    name: 'Neuromodulation Technique',
    url: `${SITE_URL}/pain-management/neuromodulation-technique/`,
    description: 'Controlled electrical stimulation to restore nerve function and reduce chronic pain signals.',
    serviceId: 'service-neuromodulation-technique',
  },
];
const breadcrumbs = [
  { name: 'Home', url: SITE_URL },
  { name: 'Pain Management', url: pageUrl },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <OfferCatalogSchema
      id="catalog-pain-management"
      name="Pain Control Clinic Services"
      description={description}
      url={pageUrl}
      services={services}
    />
    <MedicalWebPageSchema
      url={pageUrl}
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId={`${SITE_URL}/#catalog-pain-management`}
    />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>
  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Pain Control Clinic in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Pain should not dictate what you can and cannot do. Too many people in St. Peters and the surrounding St. Charles County communities accept chronic pain as normal. It is not. Morning Star offers advanced, non-surgical pain treatments that address the actual source of your discomfort, not just the symptoms on the surface.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Pain Evaluation
      </a>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Our Approach to Pain Management</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Every patient at Morning Star starts with a thorough evaluation. We review your medical history, assess your pain patterns, and identify the underlying condition before recommending a course of treatment. There is no one-size-fits-all protocol here.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Our <a href="/" class="text-brand-blue hover:underline">St. Peters medical clinic</a> combines multiple non-invasive therapies, including neuromodulation, regenerative medicine, and targeted injection treatments, to create a plan that matches your specific condition and goals. The objective is always the same: reduce your pain, restore your function, and help you return to daily life.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Pain Management Services</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/pain-management/neuropathy-treatment/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Neuropathy Treatment</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Customized treatment plans to restore peripheral nerve health and relieve neuropathic pain. Combines neuromodulation and regenerative protocols tailored to your nerve damage.
          </p>
        </a>
        <a href="/pain-management/chronic-pain-management/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Chronic Pain Management</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Personalized plans that combine regenerative, neuromodulation, and lifestyle therapies to manage persistent pain and restore quality of life.
          </p>
        </a>
        <a href="/pain-management/neuromodulation-technique/" class="bg-white rounded-xl p-6 border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue">Neuromodulation Technique</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Controlled electrical stimulation that restores nerve function, reduces chronic pain signals, and improves sensation without surgery or medication.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Conditions -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Conditions We Treat</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Our pain management services help patients in St. Peters dealing with:
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/conditions/neuropathy/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Neuropathy</span>
        </a>
        <a href="/conditions/back-pain/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Back Pain</span>
        </a>
        <a href="/conditions/neck-pain/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Neck Pain</span>
        </a>
        <a href="/conditions/sciatica/" class="bg-gray-50 rounded-lg px-5 py-4 flex items-center gap-3 hover:shadow-md transition-all group border border-gray-200">
          <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
          <span class="text-brand-navy font-medium group-hover:text-brand-blue">Sciatica</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Morning Star -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Why Choose Morning Star for Pain Management</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Many pain clinics rely heavily on prescription medications and steroid injections. Morning Star takes a different path. Our providers focus on therapies that help your body repair itself: regenerative treatments, nerve-targeted neuromodulation, and individualized protocols that adapt as you progress.
      </p>
      <p class="text-gray-600 leading-relaxed">
        We are located at 4710 Mexico Rd, Suite C in St. Peters, with easy access from I-70 and Highway 94. Patients come to us from O'Fallon, St. Charles, Wentzville, Lake St. Louis, Cottleville, and Dardenne Prairie for non-surgical pain relief they cannot find closer to home.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Take the First Step Toward Relief</h2>
      <p class="text-blue-200 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or schedule online to begin your personalized pain management plan at Morning Star in St. Peters, MO.
      </p>
      <a href="/schedule-appointment/" class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Schedule Your Evaluation
      </a>
    </div>
  </section>
</BaseLayout>
