---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Hyaluronic Acid Injections in St. Peters, MO';
const description =
  'Relieve joint pain with hyaluronic acid injections at Morning Star in St. Peters, MO. Minimally invasive joint lubrication for improved mobility.';

const faqs = [
  {
    question: 'Do hyaluronic acid injections actually work?',
    answer:
      'Effectiveness depends on the severity of your joint condition. Most patients with mild to moderate osteoarthritis experience meaningful relief — reduced pain, improved mobility, and better joint function. For advanced joint degeneration, results may be more limited. Our team will assess your condition and discuss realistic expectations during your consultation.',
  },
  {
    question: 'How long do the results last?',
    answer:
      'Results typically last between 4 to 6 months, though some patients experience relief for up to a year. The duration varies based on the severity of your condition, the joint treated, and your activity level. Repeat injections can be administered to maintain the benefits over time.',
  },
  {
    question: 'Who should not get hyaluronic acid injections?',
    answer:
      'Patients with bleeding disorders, certain allergies (particularly to hyaluronic acid or avian products, depending on the formulation), or an active infection in or around the joint should not receive these injections. Our clinical team reviews your full medical history before recommending treatment to ensure your safety.',
  },
  {
    question: 'What should I expect during the procedure?',
    answer:
      'The procedure is straightforward and performed in-office. After cleaning the injection site, a local anesthetic may be applied to minimize discomfort. The hyaluronic acid is then injected directly into the joint. The entire process typically takes 15 to 30 minutes, and most patients return to normal activities the same day.',
  },
  {
    question: 'What is the recovery time?',
    answer:
      'Recovery is minimal. You may experience mild swelling or stiffness at the injection site for 24 to 48 hours. We recommend avoiding strenuous activity for a day or two after treatment. Most patients resume their daily routine immediately and notice progressive improvement over the following weeks.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
});
---

<BaseLayout title={title} description={description} jsonLd={faqSchema}>
  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Hyaluronic Acid Injections
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Minimally invasive joint lubrication therapy designed to relieve pain, reduce stiffness, and restore mobility — without surgery or heavy medication.
      </p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">What Are Hyaluronic Acid Injections?</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Hyaluronic acid is a naturally occurring substance found in joint fluid that acts as a lubricant and shock absorber. When joints become damaged or arthritic, hyaluronic acid levels decrease, leading to increased friction, stiffness, and pain. Hyaluronic acid injections replenish this vital fluid, restoring cushioning and improving joint function.
      </p>
      <p class="text-gray-600 leading-relaxed">
        At Morning Star Neuropathy &amp; Pain Treatment Center, this minimally invasive treatment offers a faster recovery path compared to surgery, without the side effects of long-term medication use. It is especially effective for patients with mild to moderate joint conditions who want to maintain an active lifestyle.
      </p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">How the Treatment Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">1. Joint Assessment</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            We evaluate the affected joint through physical examination and imaging to determine the degree of cartilage loss and confirm that hyaluronic acid injections are appropriate.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">2. Precision Injection</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            Hyaluronic acid is injected directly into the joint space using guided techniques. A local anesthetic is applied to ensure comfort throughout the brief procedure.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">3. Progressive Relief</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            As the hyaluronic acid restores joint lubrication, patients typically notice reduced pain and improved mobility over the following weeks. Follow-up visits track your progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">Benefits of Hyaluronic Acid Injections</h2>
      <ul class="grid md:grid-cols-2 gap-4">
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Restores natural joint lubrication</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Reduces pain and stiffness without surgery</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Minimally invasive, in-office procedure</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Results lasting 4 to 6 months or longer</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">No heavy medication side effects</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Effective for mild to moderate osteoarthritis</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Move Freely Again</h2>
      <p class="text-blue-200 mb-8">
        Contact Morning Star to find out if hyaluronic acid injections can help restore comfort and mobility to your joints.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
