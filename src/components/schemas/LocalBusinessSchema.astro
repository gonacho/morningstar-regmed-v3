    ],
  },
  medicalSpecialty: [
    {
      '@type': 'MedicalSpecialty',
      name: 'Pain Medicine',
      sameAs: 'https://en.wikipedia.org/wiki/Pain_management',
    },
    {
      '@type': 'MedicalSpecialty',
      name: 'Musculoskeletal Medicine',
    },
  ],
  // hasMap: 'https://www.google.com/maps/search/?api=1&query=Morning+Star+Neuropathy+%26+Pain+Treatment+Center&query_place_id=PENDING',
  sameAs: [
    'https://www.facebook.com/p/Morningstar-Neuropathy-Pain-Treatment-Center-St-Peters-100070536960997/',
    'https://www.carecredit.com/doctor-locator/st-peters-mo/morningstar-neuropathy-pain-treatment-center-llc-854dgw/',
