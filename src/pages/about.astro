---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';

const SITE_URL = 'https://morningstarregmed.com';
const pageUrl = `${SITE_URL}/about/`;
const title = 'About Morning Star | Pain & Neuropathy Clinic in St. Peters, MO';
const description =
  'Learn about Morning Star Neuropathy & Pain Treatment Center in St. Peters, MO. Our approach to non-surgical pain relief and regenerative care.';

const breadcrumbs = [
  { name: 'Home', url: SITE_URL },
  { name: 'About', url: pageUrl },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalWebPageSchema
      url={pageUrl}
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId={`${SITE_URL}/#organization`}
    />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-muted" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-primary">Home</a></li>
      <li>/</li>
      <li class="text-dark font-medium">About</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="relative bg-dark py-24 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-muted to-primary/30"></div>
    <div class="relative section-container text-center">
      <span class="inline-flex items-center gap-1.5 bg-accent/20 text-accent border border-accent/30 text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full mb-5">
        Morning Star · St. Peters, MO
      </span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-white leading-tight mb-5">
        About Morning Star Neuropathy &amp; Pain Treatment Center
      </h1>
      <p class="text-white/75 text-lg max-w-2xl mx-auto">
        Helping patients in St. Peters and the greater St. Louis area find lasting relief from neuropathy and chronic pain through advanced, non-invasive care since 2009.
      </p>
    </div>
  </section>

  <!-- Clinic Story -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Our Story</h2>
      <p class="text-body text-lg leading-relaxed mb-6">
        Morning Star Neuropathy &amp; Pain Treatment Center was founded to serve people in St. Peters, St. Charles County, and the greater St. Louis metropolitan area who had been told their only options were long-term medication, repeated cortisone injections, or surgery. That answer was not good enough.
      </p>
      <p class="text-body text-lg leading-relaxed mb-6">
        We built a clinic around a different premise: advanced, non-invasive treatments that go after the actual source of pain. Regenerative therapies, neuromodulation, PRP, hyaluronic acid injections, and medically supervised weight loss were once limited to major academic medical centers. Morning Star brought them to a comfortable, patient-focused setting on Mexico Rd in St. Peters so that people across the region could access these treatments close to home.
      </p>
      <p class="text-body text-lg leading-relaxed">
        We measure our success by the quality of life our patients reclaim: the grandmother who can walk to the mailbox again, the mechanic who returned to work without daily pain medication, the retiree who started golfing again after two years on the sideline. Those outcomes drive everything we do.
      </p>
    </div>
  </section>

  <!-- Treatment Philosophy -->
  <section class="bg-bg-warm py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Our Treatment Philosophy</h2>
      <p class="text-body text-lg leading-relaxed mb-6">
        Every treatment decision at Morning Star starts with one question: what is causing this patient's pain? We believe lasting relief is only possible when the root cause is identified and addressed directly. That is why every new patient receives a thorough evaluation, including a health history review, neurological assessment, and diagnostic workup, before any treatment is recommended.
      </p>
      <p class="text-body text-lg leading-relaxed mb-6">
        We combine advanced technologies like <a href="/pain-management/neuromodulation-technique/" class="text-primary hover:underline">neuromodulation</a>, <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-primary hover:underline">platelet-rich plasma therapy</a>, <a href="/regenerative-medicine/regenerative-therapy/" class="text-primary hover:underline">exosome-based regenerative therapy</a>, and <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary hover:underline">hyaluronic acid injections</a> with individualized care plans tailored to each patient's condition, lifestyle, and goals. There is no one-size-fits-all protocol at this clinic.
      </p>
      <p class="text-body text-lg leading-relaxed">
        We are committed to transparency at every step. Patients understand exactly what their treatment involves, why it was recommended, and what outcomes they can realistically expect.
      </p>
    </div>
  </section>

  <!-- Our Team -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Our Team</h2>
      <p class="text-body text-lg leading-relaxed mb-6">
        The clinical team at Morning Star includes experienced medical professionals who specialize in neuropathy, <a href="/pain-management/" class="text-primary hover:underline">pain management</a>, and <a href="/regenerative-medicine/" class="text-primary hover:underline">regenerative medicine</a>. Our practitioners hold advanced training in neuromodulation techniques, PRP therapy, exosome therapy, hyaluronic acid joint injections, and medically supervised weight management.
      </p>
      <p class="text-body text-lg leading-relaxed">
        Continuous education is a cornerstone of our practice. Our providers regularly attend national conferences, complete advanced certifications, and stay current with peer-reviewed research. When new evidence supports a better approach, we adopt it.
      </p>
    </div>
  </section>

  <!-- Community -->
  <section class="bg-bg-warm py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-dark text-center mb-6">Serving St. Peters and the Greater St. Louis Region</h2>
      <p class="text-body text-lg leading-relaxed text-center max-w-3xl mx-auto mb-12">
        Our clinic is located at 4710 Mexico Rd, Suite C in St. Peters, near Mid Rivers Mall Drive, with easy access from I-70 and Highway 94. We welcome patients from across the region.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          'St. Peters', "O'Fallon", 'St. Charles', 'Wentzville',
          'Lake St. Louis', 'Cottleville', 'Dardenne Prairie', 'Chesterfield',
        ].map((city) => (
          <div class="bg-white rounded-xl px-5 py-4 flex items-center gap-3 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-primary flex-shrink-0"></span>
            <span class="text-dark font-medium">{city}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl text-white mb-4">Ready to Start Your Recovery?</h2>
      <p class="text-white/80 text-lg mb-8">
        Take the first step toward lasting pain relief. Consultations are free — no obligation.
      </p>
      <a href="/schedule-appointment/" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg">
        Schedule Free Consultation →
      </a>
      <p class="text-white/50 text-sm mt-4">📞 (636) 244-0124 · Mon–Thu 8am–5pm</p>
    </div>
  </section>
</BaseLayout>
