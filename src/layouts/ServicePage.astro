---
import BaseLayout from '@/layouts/BaseLayout.astro';

export interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  metaDescription: string;
  h1: string;
  heroText: string;
  faqs?: FAQ[];
  /** Optional pre-serialised JSON-LD to pass through to BaseLayout */
  jsonLd?: string;
}

const { title, metaDescription, h1, heroText, faqs = [], jsonLd } = Astro.props;

const faqSchema =
  faqs.length > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map(({ question, answer }) => ({
          '@type': 'Question',
          name: question,
          acceptedAnswer: { '@type': 'Answer', text: answer },
        })),
      })
    : undefined;

const resolvedJsonLd = jsonLd ?? faqSchema;
---

<BaseLayout title={title} description={metaDescription} jsonLd={resolvedJsonLd}>
  <!-- Hero -->
  <section class="relative bg-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-muted to-primary/30"></div>
    <div class="relative section-container py-20 lg:py-28">
      <span class="inline-flex items-center gap-1.5 bg-accent/20 text-accent border border-accent/30 text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full mb-5">
        Morning Star · St. Peters, MO
      </span>
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-white mb-5 max-w-2xl leading-tight">{h1}</h1>
      <p class="text-white/75 text-lg leading-relaxed max-w-xl mb-8">{heroText}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/schedule-appointment/" class="btn-primary">
          Book Free Consultation →
        </a>
        <a href="tel:+16362440124" class="btn-ghost">
          (636) 244-0124
        </a>
      </div>
    </div>
  </section>

  <!-- Body content slot -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-4xl mx-auto prose prose-lg prose-headings:font-heading prose-headings:text-dark prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-dark">
      <slot />
    </div>
  </section>

  <!-- FAQs -->
  {faqs.length > 0 && (
    <section class="bg-bg-cream py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading font-bold text-3xl text-dark mb-8">Frequently Asked Questions</h2>
        <dl class="space-y-4">
          {faqs.map(({ question, answer }) => (
            <div class="bg-white rounded-2xl p-6 border border-border shadow-sm">
              <dt class="font-heading font-semibold text-dark mb-2">{question}</dt>
              <dd class="text-body text-sm leading-relaxed">{answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <!-- CTA Block -->
  <section class="bg-primary py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl text-white mb-4">Ready to Start Your Recovery?</h2>
      <p class="text-white/80 text-lg mb-8">
        Take the first step toward lasting pain relief. Consultations are free — no obligation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/schedule-appointment/" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg">
          Schedule Free Consultation →
        </a>
        <a href="/contact/" class="inline-flex items-center gap-2 border-2 border-white/40 text-white font-heading font-semibold text-base px-8 py-4 rounded-full hover:border-white/70 transition-all duration-200">
          Contact Us
        </a>
      </div>
      <p class="text-white/50 text-sm mt-5">📞 (636) 244-0124 · Mon–Thu 8am–5pm</p>
    </div>
  </section>
</BaseLayout>
