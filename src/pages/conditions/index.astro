---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';

const SITE_URL = 'https://morningstarregmed.com';
const pageUrl = `${SITE_URL}/conditions/`;
const title = 'Conditions We Treat in St. Peters, MO | Morning Star';
const description =
  'Find relief for neuropathy, knee pain, back pain, neck pain, joint pain, and sciatica at Morning Star in St. Peters, MO. Learn about your condition.';
const breadcrumbs = [
  { name: 'Home', url: SITE_URL },
  { name: 'Conditions', url: pageUrl },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalWebPageSchema
      url={pageUrl}
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
    />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>
  <!-- Hero -->
  <section class="bg-bg-warm py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-6">
        Conditions We Treat in St. Peters, MO
      </h1>
      <p class="text-xl text-body max-w-2xl">
        Pain has a cause. Finding it is the first step toward fixing it. At Morning Star, we treat a range of nerve, joint, and spinal conditions using non-surgical therapies that target the problem at its source. Select a condition below to learn about causes, symptoms, and the treatment options available to you.
      </p>
    </div>
  </section>

  <!-- Condition Grid -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/conditions/neuropathy/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Neuropathy</h2>
          <p class="text-body text-sm leading-relaxed">
            Peripheral nerve damage causing tingling, numbness, burning pain, and balance problems in the hands and feet. Treated with neuromodulation, regenerative therapy, and customized nerve rehabilitation.
          </p>
        </a>
        <a href="/conditions/knee-pain/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Knee Pain</h2>
          <p class="text-body text-sm leading-relaxed">
            Osteoarthritis, cartilage loss, and joint degeneration that limit mobility and daily activities. Treated with PRP therapy, hyaluronic acid injections, and regenerative therapy.
          </p>
        </a>
        <a href="/conditions/back-pain/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Back Pain</h2>
          <p class="text-body text-sm leading-relaxed">
            Herniated discs, degenerative disc disease, and chronic lower back pain that interferes with work and sleep. Treated with regenerative therapy, chronic pain management, and PRP therapy.
          </p>
        </a>
        <a href="/conditions/neck-pain/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Neck Pain</h2>
          <p class="text-body text-sm leading-relaxed">
            Cervical strain, stiffness, and radiating pain from spinal conditions or postural damage. Treated with neuromodulation and chronic pain management.
          </p>
        </a>
        <a href="/conditions/joint-pain/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Joint Pain</h2>
          <p class="text-body text-sm leading-relaxed">
            Osteoarthritis, joint inflammation, and progressive stiffness affecting shoulders, hips, and other joints. Treated with PRP therapy, hyaluronic acid injections, and regenerative therapy.
          </p>
        </a>
        <a href="/conditions/sciatica/" class="bg-white rounded-2xl p-6 border border-border hover:shadow-md hover:border-primary transition-all group">
          <h2 class="font-semibold text-lg text-dark mb-2 group-hover:text-primary">Sciatica</h2>
          <p class="text-body text-sm leading-relaxed">
            Sciatic nerve compression causing radiating leg pain, numbness, and weakness from the lower back. Treated with neuromodulation, chronic pain management, and regenerative therapy.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="bg-bg-warm py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">How We Approach Condition-Specific Care</h2>
      <p class="text-body leading-relaxed mb-4">
        Every condition has a different root cause, and every patient experiences it differently. That is why Morning Star does not use generic treatment templates. We start with a thorough evaluation of your specific condition, including your symptoms, medical history, and diagnostic findings. Then we build a treatment plan using the <a href="/pain-management/" class="text-primary hover:underline">pain management</a> and <a href="/regenerative-medicine/" class="text-primary hover:underline">regenerative medicine therapies</a> that match your situation.
      </p>
      <p class="text-body leading-relaxed">
        The condition pages above explain what causes each problem, the symptoms to watch for, and the specific services we offer to treat them. If you are unsure which condition applies to your pain, <a href="/schedule-appointment/" class="text-primary hover:underline">schedule an evaluation</a> and our team will help you find the answer.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Find Out What Is Causing Your Pain</h2>
      <p class="text-white/70 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or schedule online. Our St. Peters team will evaluate your condition and explain your treatment options.
      </p>
      <a href="/schedule-appointment/" class="px-8 py-3 bg-white text-dark font-semibold rounded-xl hover:bg-blue-50 transition-colors">
        Schedule Your Evaluation
      </a>
    </div>
  </section>
</BaseLayout>
