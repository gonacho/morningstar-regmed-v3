---
const currentPath = Astro.url.pathname;

const painServices = [
  { href: '/pain-management/neuropathy-treatment/', label: 'Neuropathy Treatment' },
  { href: '/pain-management/chronic-pain-management/', label: 'Chronic Pain Management' },
  { href: '/pain-management/neuromodulation-technique/', label: 'Neuromodulation Technique' },
];

const regenServices = [
  { href: '/regenerative-medicine/regenerative-therapy/', label: 'Regenerative Therapy' },
  { href: '/regenerative-medicine/platelet-rich-plasma-therapy/', label: 'PRP Therapy' },
  { href: '/regenerative-medicine/hyaluronic-acid-injections/', label: 'Hyaluronic Acid Injections' },
];

const conditions = [
  { href: '/conditions/neuropathy/', label: 'Neuropathy' },
  { href: '/conditions/knee-pain/', label: 'Knee Pain' },
  { href: '/conditions/back-pain/', label: 'Back Pain' },
  { href: '/conditions/neck-pain/', label: 'Neck Pain' },
  { href: '/conditions/joint-pain/', label: 'Joint Pain' },
  { href: '/conditions/sciatica/', label: 'Sciatica' },
];
---

<header id="site-header" class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <span class="text-brand-navy font-bold text-xl tracking-tight leading-tight">
          Morning Star
          <span class="block text-xs font-normal text-gray-500 tracking-wide">Neuropathy & Pain</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-brand-navy rounded-md transition-colors group-hover:text-brand-navy"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <!-- Mega menu -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 w-[640px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-6 grid grid-cols-3 gap-6">
              <!-- Pain Management -->
              <div>
                <a href="/pain-management/" class="block text-xs font-semibold text-brand-blue uppercase tracking-widest mb-3 hover:underline">
                  Pain Management
                </a>
                <ul class="space-y-2">
                  {painServices.map(({ href, label }) => (
                    <li>
                      <a href={href} class="text-sm text-gray-600 hover:text-brand-navy hover:font-medium transition-colors block py-0.5">
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Regenerative Medicine -->
              <div>
                <a href="/regenerative-medicine/" class="block text-xs font-semibold text-brand-blue uppercase tracking-widest mb-3 hover:underline">
                  Regenerative Medicine
                </a>
                <ul class="space-y-2">
                  {regenServices.map(({ href, label }) => (
                    <li>
                      <a href={href} class="text-sm text-gray-600 hover:text-brand-navy hover:font-medium transition-colors block py-0.5">
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <!-- Weight Loss -->
              <div>
                <span class="block text-xs font-semibold text-brand-blue uppercase tracking-widest mb-3">
                  Weight Loss
                </span>
                <a href="/medical-weight-loss/" class="text-sm text-gray-600 hover:text-brand-navy hover:font-medium transition-colors block py-0.5">
                  Medical Weight Loss
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Conditions dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-brand-navy rounded-md transition-colors group-hover:text-brand-navy"
            aria-haspopup="true"
          >
            Conditions
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 py-2">
              {conditions.map(({ href, label }) => (
                <a href={href} class="block px-4 py-2 text-sm text-gray-600 hover:bg-brand-light hover:text-brand-navy transition-colors">
                  {label}
                </a>
              ))}
              <div class="border-t border-gray-100 mt-1 pt-1">
                <a href="/conditions/" class="block px-4 py-2 text-sm font-medium text-brand-blue hover:bg-brand-light transition-colors">
                  View All Conditions →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Static links -->
        <a href="/about/" class:list={['px-3 py-2 text-sm font-medium rounded-md transition-colors', currentPath.startsWith('/about') ? 'text-brand-blue' : 'text-gray-600 hover:text-brand-navy']}>
          About
        </a>
        <a href="/contact/" class:list={['px-3 py-2 text-sm font-medium rounded-md transition-colors', currentPath.startsWith('/contact') ? 'text-brand-blue' : 'text-gray-600 hover:text-brand-navy']}>
          Contact
        </a>
        <a href="/blog/" class:list={['px-3 py-2 text-sm font-medium rounded-md transition-colors', currentPath.startsWith('/blog') ? 'text-brand-blue' : 'text-gray-600 hover:text-brand-navy']}>
          Blog
        </a>

        <!-- CTA -->
        <a
          href="/schedule-appointment/"
          class="ml-3 px-5 py-2 bg-brand-blue text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap"
        >
          Schedule Evaluation
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-gray-600 hover:text-brand-navy"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" id="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100">
      <div class="py-4 space-y-1">
        <!-- Services group -->
        <div>
          <div class="px-4 py-2 text-xs font-semibold text-brand-blue uppercase tracking-widest">Pain Management</div>
          {painServices.map(({ href, label }) => (
            <a href={href} class="block px-6 py-2 text-sm text-gray-600 hover:text-brand-navy">
              {label}
            </a>
          ))}
        </div>
        <div>
          <div class="px-4 py-2 text-xs font-semibold text-brand-blue uppercase tracking-widest">Regenerative Medicine</div>
          {regenServices.map(({ href, label }) => (
            <a href={href} class="block px-6 py-2 text-sm text-gray-600 hover:text-brand-navy">
              {label}
            </a>
          ))}
        </div>
        <div>
          <div class="px-4 py-2 text-xs font-semibold text-brand-blue uppercase tracking-widest">Weight Loss</div>
          <a href="/medical-weight-loss/" class="block px-6 py-2 text-sm text-gray-600 hover:text-brand-navy">Medical Weight Loss</a>
        </div>

        <div class="border-t border-gray-100 pt-2">
          <div class="px-4 py-2 text-xs font-semibold text-brand-blue uppercase tracking-widest">Conditions</div>
          {conditions.map(({ href, label }) => (
            <a href={href} class="block px-6 py-2 text-sm text-gray-600 hover:text-brand-navy">
              {label}
            </a>
          ))}
          <a href="/conditions/" class="block px-6 py-2 text-sm font-medium text-brand-blue">View All Conditions →</a>
        </div>

        <div class="border-t border-gray-100 pt-2 space-y-1">
          <a href="/about/" class="block px-4 py-2 text-sm text-gray-600 hover:text-brand-navy">About</a>
          <a href="/contact/" class="block px-4 py-2 text-sm text-gray-600 hover:text-brand-navy">Contact</a>
          <a href="/blog/" class="block px-4 py-2 text-sm text-gray-600 hover:text-brand-navy">Blog</a>
        </div>

        <div class="pt-2 px-4">
          <a href="/schedule-appointment/" class="block w-full text-center py-3 bg-brand-blue text-white text-sm font-semibold rounded-lg">
            Schedule Evaluation
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden', !isOpen ? false : false);
    // swap icons
    if (isOpen) {
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    } else {
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      btn?.setAttribute('aria-expanded', 'true');
    }
  });
</script>
