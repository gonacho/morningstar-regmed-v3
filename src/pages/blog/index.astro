---
import BaseLayout from '@/layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'regenerative-therapy-back-pain-recovery',
    title: 'How Regenerative Therapy May Support Back Pain Recovery',
    date: '2026-04-06',
    excerpt: 'Patients dealing with persistent back pain often look for options beyond traditional approaches. Learn how regenerative therapy at Morning Star supports tissue health and long-term spine stability through cellular repair and non-invasive care.',
  },
  {
    slug: 'neuropathy-treatment-long-term-support',
    title: 'Neuropathy Treatment for Long-Term Nerve Function Support',
    date: '2026-04-02',
    excerpt: 'Neuropathy affects daily activities like walking and driving. Discover how clinical protocols at Morning Star, including neuromodulation and vascular support, help restore nerve communication and improve quality of life.',
  },
];
---

<BaseLayout
  title="Blog"
  description="Health tips and insights from Morning Star in St. Peters, MO. Learn about neuropathy, pain management, regenerative therapy, and wellness strategies."
>
  <!-- Hero -->
  <section class="bg-bg-warm py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-dark mb-4">Morning Star Blog</h1>
      <p class="text-xl text-body">
        Health tips and insights on neuropathy, pain management, regenerative therapy, and wellness strategies from our team in St. Peters, MO.
      </p>
    </div>
  </section>

  <!-- Post listing -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map(({ slug, title, date, excerpt }) => (
        <article class="border border-border rounded-2xl p-6 hover:shadow-md transition-shadow flex flex-col">
          <time class="text-sm text-muted mb-2 block">
            {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2 class="text-xl font-bold text-dark mb-3">
            <a href={`/blog/${slug}`} class="hover:text-primary transition-colors">
              {title}
            </a>
          </h2>
          <p class="text-body text-sm mb-4 flex-1">{excerpt}</p>
          <a
            href={`/blog/${slug}`}
            class="text-primary text-sm font-medium hover:underline"
          >
            Read more &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
