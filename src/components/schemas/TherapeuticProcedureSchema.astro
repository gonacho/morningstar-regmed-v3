---
/**
 * Block D-service — TherapeuticProcedure
 * Used on: All service pages
 */

interface Review {
  author: string;
  datePublished: string;
  reviewBody: string;
  ratingValue?: string;
}

interface Props {
  id: string;            // @id fragment — e.g. 'service-neuropathy-treatment'
  name: string;
  description: string;
  url: string;
  publishDate: string;
  lastEdited: string;
  indication?: string[];          // @id fragments of related MedicalCondition entities
  bodyLocation?: string[];
  reviews?: Review[];
  aggregateRating?: { ratingValue: string; reviewCount: string };
  howPerformed?: string;
  preparation?: string;
}

const {
  id,
  name,
  description,
  url,
  publishDate,
  lastEdited,
  indication = [],
  bodyLocation = [],
  reviews = [],
  aggregateRating,
  howPerformed,
  preparation,
} = Astro.props;

const SITE_URL = 'https://morningstarregmed.com';

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'TherapeuticProcedure',
  '@id': `${SITE_URL}/#${id}`,
  name,
  description,
  url,
  provider: { '@id': `${SITE_URL}/#localbusiness` },
  isPartOf: { '@id': `${SITE_URL}/#organization` },
  datePublished: publishDate,
  dateModified: lastEdited,  // v3: from lastEdited prop — NEVER new Date()
};

if (indication.length > 0) {
  schema.indication = indication.map((condId) => ({
    '@id': `${SITE_URL}/#${condId}`,
  }));
}

if (bodyLocation.length > 0) {
  schema.bodyLocation = bodyLocation;
}

if (howPerformed) {
  schema.howPerformed = howPerformed;
}

if (preparation) {
  schema.preparation = preparation;
}

if (reviews.length > 0) {
  schema.review = reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.author },
    datePublished: r.datePublished,
    reviewBody: r.reviewBody,  // VERBATIM — no transformation
    reviewRating: {
      '@type': 'Rating',
      ratingValue: r.ratingValue ?? '5',
      bestRating: '5',
    },
  }));
}

if (aggregateRating) {
  schema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: aggregateRating.ratingValue,
    reviewCount: aggregateRating.reviewCount,
    bestRating: '5',
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
