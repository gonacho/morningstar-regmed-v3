---
import BaseLayout from '@/layouts/BaseLayout.astro';

// In Astro static output, getStaticPaths() runs in module scope (before the
// frontmatter instance). Define posts as a module-level constant so it is
// accessible from both getStaticPaths() and the component frontmatter.
// SEO Writer will populate body content in Phase 2.
// Slugs match the redirect destinations in public/_redirects.

type Post = {
  slug: string;
  title: string;
  metaDescription: string;
  date: string;
  body: string;
};

const POSTS: Post[] = [
  {
    slug: 'regenerative-therapy-back-pain-recovery',
    title: 'How Regenerative Therapy May Support Back Pain Recovery',
    metaDescription:
      'Discover how regenerative therapy at Morning Star may help support back pain recovery and improve long-term outcomes.',
    date: '2024-01-15',
    body: '<p>Placeholder — content coming in Phase 2.</p>',
  },
  {
    slug: 'neuropathy-treatment-long-term-support',
    title: 'Neuropathy Treatment for Long-Term Nerve Function Support',
    metaDescription:
      'Learn how neuropathy treatment at Morning Star in St. Peters, MO can support long-term nerve function and quality of life.',
    date: '2024-02-10',
    body: '<p>Placeholder — content coming in Phase 2.</p>',
  },
];

export function getStaticPaths() {
  const POSTS: Post[] = [
    {
      slug: 'regenerative-therapy-back-pain-recovery',
      title: 'How Regenerative Therapy May Support Back Pain Recovery',
      metaDescription:
        'Discover how regenerative therapy at Morning Star may help support back pain recovery and improve long-term outcomes.',
      date: '2024-01-15',
      body: '<p>Placeholder — content coming in Phase 2.</p>',
    },
    {
      slug: 'neuropathy-treatment-long-term-support',
      title: 'Neuropathy Treatment for Long-Term Nerve Function Support',
      metaDescription:
        'Learn how neuropathy treatment at Morning Star in St. Peters, MO can support long-term nerve function and quality of life.',
      date: '2024-02-10',
      body: '<p>Placeholder — content coming in Phase 2.</p>',
    },
  ];
  return POSTS.map((post) => ({ params: { slug: post.slug }, props: post }));
}

const { title, metaDescription, date, body } = Astro.props as Post;
---

<BaseLayout title={title} description={metaDescription}>
  <!-- Article header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <a href="/blog" class="text-sm text-brand-blue hover:underline mb-4 inline-block">
        ← Back to Blog
      </a>
      <h1 class="text-4xl font-bold text-brand-navy mb-4">{title}</h1>
      <time class="text-sm text-gray-500">
        {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
  </section>

  <!-- Article body -->
  <article class="py-16 px-4">
    <div
      class="max-w-3xl mx-auto prose prose-lg prose-headings:text-brand-navy prose-a:text-brand-blue"
      set:html={body}
    />
  </article>

  <!-- CTA -->
  <section class="bg-brand-light py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Ready to start your treatment?</h2>
      <p class="text-gray-600 mb-6">Contact Morning Star to schedule a consultation.</p>
      <a
        href="/schedule-appointment"
        class="px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</BaseLayout>
