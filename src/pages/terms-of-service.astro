---
import BaseLayout from '@/layouts/BaseLayout.astro';

const lastUpdated = '2024-01-01';
---

<BaseLayout
  title="Terms of Service"
  description="Morningstar RegMed terms of service — the rules governing your use of our website and services."
>
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Terms of Service</h1>
      <p class="text-gray-500 text-sm">
        Last updated:{' '}
        {new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </section>

  <!-- Terms body -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto prose prose-lg prose-headings:text-brand-navy">
      <p>
        Placeholder — full terms of service content coming in Phase 2. This page will cover
        acceptance of terms, use of the website, medical disclaimer, intellectual property,
        limitation of liability, and governing law.
      </p>

      <h2>Acceptance of Terms</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Medical Disclaimer</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Use of the Website</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Intellectual Property</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Limitation of Liability</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Governing Law</h2>
      <p>Placeholder — content coming in Phase 2.</p>

      <h2>Contact Us</h2>
      <p>
        For questions about these terms, please use our{' '}
        <a href="/contact">contact page</a>.
      </p>
    </div>
  </section>
</BaseLayout>
