---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Joint Pain Treatment in St. Peters, MO | Morning Star';
const description =
  'Get expert joint pain relief at Morning Star in St. Peters, MO. Diagnosis and treatment for osteoarthritis, stiffness, and joint inflammation.';

const faqs = [
  {
    question: 'What are the most common causes of joint pain?',
    answer:
      'Osteoarthritis is the leading cause of joint pain, especially in adults over 50. Other common causes include inflammatory arthritis (such as rheumatoid arthritis), overuse or repetitive stress injuries, ligament or tendon damage, and age-related cartilage degeneration. Many patients experience joint pain from a combination of wear-and-tear and underlying inflammatory processes.',
  },
  {
    question: 'Are there home remedies that help with joint pain?',
    answer:
      'Gentle low-impact exercise (walking, swimming, cycling), maintaining a healthy weight, applying ice or heat to affected joints, and over-the-counter anti-inflammatory medications can provide temporary relief. These approaches work best alongside professional treatment. If your joint pain persists for more than a few weeks, a clinical evaluation can identify the cause and determine whether more targeted therapies are needed.',
  },
  {
    question: 'When should I see a doctor for joint pain?',
    answer:
      'You should see a doctor if your joint pain lasts longer than two to three weeks, is accompanied by swelling or redness, limits your ability to move the joint through its full range of motion, or worsens over time despite rest and home care. Sudden, severe joint pain following an injury also warrants prompt evaluation.',
  },
  {
    question: 'What joint pain treatments does Morning Star offer?',
    answer:
      'Morning Star offers PRP (platelet-rich plasma) therapy, hyaluronic acid injections, and regenerative therapy for joint pain. Each treatment is selected based on your diagnosis, the severity of your condition, and the specific joint affected. Our team develops a personalized plan that may combine multiple therapies for the best possible outcome.',
  },
  {
    question: 'How can I prevent joint pain from getting worse?',
    answer:
      'Staying active with joint-friendly exercises, maintaining a healthy body weight, protecting joints during repetitive activities, and addressing early symptoms before they progress are the most effective prevention strategies. Patients who complete treatment at Morning Star receive specific guidance on exercises and lifestyle modifications designed to protect their joints long-term.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
});
---

<BaseLayout title={title} description={description} jsonLd={faqSchema}>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-gray-500" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-brand-blue">Home</a></li>
      <li>/</li>
      <li><a href="/conditions/" class="hover:text-brand-blue">Conditions</a></li>
      <li>/</li>
      <li class="text-brand-navy font-medium">Joint Pain</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Joint Pain Treatment in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Expert diagnosis and targeted treatment for <strong>joint pain</strong>, from early-stage stiffness to advanced osteoarthritis. Our regenerative therapies help restore mobility and reduce inflammation without surgery.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a
          href="/schedule-appointment"
          class="inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
        >
          Schedule a Consultation
        </a>
        <a
          href="tel:6362440124"
          class="inline-block px-8 py-3 border-2 border-brand-blue text-brand-blue font-semibold rounded-lg hover:bg-brand-blue hover:text-white transition-colors"
        >
          Call (636) 244-0124
        </a>
      </div>
    </div>
  </section>

  <!-- Understanding Joint Pain -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Understanding Joint Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Joints are where two or more bones meet, cushioned by cartilage and supported by ligaments, tendons, and a thin lining called the synovial membrane. When any part of this system is damaged or inflamed, the result is pain, stiffness, and reduced mobility. <strong>Joint pain</strong> can affect any joint in the body, though the knees, hips, shoulders, and hands are most commonly involved.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        The condition ranges from mild discomfort during certain movements to severe, constant pain that interferes with walking, sleeping, and basic daily tasks. Some patients notice gradual worsening over months or years. Others experience sudden flare-ups that seem to come from nowhere.
      </p>
      <p class="text-gray-600 leading-relaxed">
        At Morning Star Neuropathy &amp; Pain Treatment Center in St. Peters, MO, we evaluate the specific cause of your joint pain and match it with the most appropriate therapy. Our focus is on treatments that support the joint's natural healing processes rather than relying solely on medication to mask the symptoms.
      </p>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">Common Causes of Joint Pain</h2>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Osteoarthritis</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        <strong>Osteoarthritis</strong> is the most prevalent form of arthritis, affecting more than 32 million adults in the United States. It develops when the protective cartilage that cushions the ends of your bones wears down over time, leading to bone-on-bone contact, inflammation, and progressive pain. Weight-bearing joints (knees, hips) and the hands are most frequently affected.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Inflammatory Arthritis</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Conditions like rheumatoid arthritis and psoriatic arthritis involve the immune system attacking the joint lining. This produces swelling, warmth, and pain that can affect multiple joints simultaneously. Unlike osteoarthritis, inflammatory arthritis often presents with morning stiffness lasting 30 minutes or longer.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Overuse &amp; Repetitive Stress</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Repetitive motions at work, during sports, or through daily activities can irritate the tendons and bursae surrounding a joint. Tennis elbow, rotator cuff tendinitis, and runner's knee are common examples. These injuries often respond well to rest initially, but without proper treatment they tend to recur.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Injuries</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Sprains, dislocations, and fractures can cause both immediate joint pain and long-term damage if not properly treated. Even after the initial injury heals, the affected joint may develop early-onset arthritis or chronic instability that leads to persistent discomfort.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Age-Related Degeneration</h3>
      <p class="text-gray-600 leading-relaxed">
        Cartilage naturally thins with age, and the synovial fluid that lubricates your joints decreases in both volume and quality. These changes increase friction within the joint and make it more susceptible to pain, particularly during activities that involve bending, climbing stairs, or gripping objects.
      </p>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Symptoms of Joint Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Joint pain symptoms vary based on the cause and the specific joint involved. Watch for these common signs:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Aching or soreness in or around a joint, especially after activity</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Stiffness that is worse in the morning or after sitting for extended periods</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Swelling, warmth, or visible redness around the joint</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Reduced range of motion or difficulty bending the joint fully</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> A grinding or clicking sensation during movement</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Weakness or instability in the affected joint</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Pain that worsens in cold or damp weather</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Difficulty with daily tasks such as climbing stairs, opening jars, or walking</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        If these symptoms persist or progressively worsen, professional evaluation can determine the cause and help you start treatment before further damage occurs.
      </p>
    </div>
  </section>

  <!-- Treatment at Morning Star -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Joint Pain Treatment at Morning Star</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        We start every joint pain case with a detailed evaluation, including a review of your symptoms, medical history, and any previous imaging or lab work. This allows our team to identify the specific type of joint damage present and select the treatment most likely to help. Morning Star offers several non-surgical options designed to reduce pain, decrease inflammation, and support the joint's own healing capacity.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">PRP Therapy</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-brand-blue hover:underline">Platelet-rich plasma (PRP) therapy</a> uses a concentrated preparation of your own blood platelets, which are rich in growth factors that promote tissue repair. When injected into a damaged joint, PRP can reduce inflammation, stimulate cartilage regeneration, and decrease pain over a series of treatments.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Hyaluronic Acid Injections</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-brand-blue hover:underline">Hyaluronic acid (HA) injections</a> restore lubrication to joints where natural synovial fluid has thinned. This treatment is particularly effective for <strong>knee osteoarthritis</strong> and other weight-bearing joint conditions, reducing friction and improving comfort during movement.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Regenerative Therapy</h3>
      <p class="text-gray-600 leading-relaxed">
        Our <a href="/regenerative-medicine/regenerative-therapy/" class="text-brand-blue hover:underline">regenerative therapy</a> program targets damaged joint tissue at the cellular level, encouraging the body's own repair mechanisms. For patients with moderate to advanced joint degeneration, regenerative therapy offers an alternative to joint replacement surgery and long-term medication dependence.
      </p>
    </div>
  </section>

  <!-- When to See a Doctor -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">When to See a Doctor for Joint Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Occasional joint soreness after a long day or a tough workout is normal. However, you should schedule a professional evaluation if your joint pain:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Persists for more than two to three weeks</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Is accompanied by significant swelling or redness</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Limits your ability to perform daily activities</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Worsens over time despite rest and home care</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Follows a fall, collision, or other injury</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        Joint damage tends to be progressive. The earlier you seek treatment, the more options are available to slow or reverse the damage. Our St. Peters team is ready to help you understand what is happening in your joint and what can be done about it.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Take Control of Your Joint Pain</h2>
      <p class="text-blue-200 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or schedule online. Our St. Peters team will evaluate your joints, explain your diagnosis, and build a treatment plan around your needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="tel:6362440124"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Call (636) 244-0124
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
