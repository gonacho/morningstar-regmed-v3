---
/**
 * Block B — MedicalClinic + LocalBusiness
 * Used on: Homepage (with reviews) + Contact page (reference only)
 * CID/PlaceID: PENDING administrator approval
 * Institutional Anchors: PENDING administrator selection
 */

interface Props {
  includeReviews?: boolean;
}

const { includeReviews = false } = Astro.props;

const SITE_URL = 'https://morningstarregmed.com';

// Verbatim GBP review — Clyde Steese (approved, bound to homepage/LocalBusiness)
const homepageReview = {
  '@type': 'Review',
  author: { '@type': 'Person', name: 'Clyde Steese' },
  datePublished: '2024-01-01',
  reviewBody:
    'The people working here are fantastic. They are great help with everything. The treatments were just fantastic. They started off slow but then they started picking up and they have finished and I am 100% very very happy with everything. Thank you so very much the end.',
  reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
};

