---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us"
  description="Learn about Morningstar Neuropathy & Pain Treatment Center in St. Peters, MO — our mission, team, and approach to non-invasive pain management."
>
  <!-- Hero -->
  <section class="bg-brand-light py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-brand-navy leading-tight mb-6">
        About Morningstar Neuropathy & Pain Treatment Center
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        We are dedicated to helping patients in St. Peters, MO and the greater St. Louis area live pain-free lives through comprehensive, non-invasive care.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Our Mission</h2>
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        At Morningstar Neuropathy & Pain Treatment Center, our mission is to provide comprehensive services that help you live a pain-free life — without the need for medication or invasive procedures. We specialize in identifying the root cause of your pain and building a personalized treatment plan that works for your body and lifestyle.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        We believe that lasting relief comes from understanding the full picture of a patient's health — not just managing symptoms. Our clinical team takes the time to review your background, current symptoms, and history to develop an evidence-based roadmap for your recovery.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed">
        Whether you're dealing with neuropathy, chronic pain, joint issues, or back problems, we have the expertise and tools to help you regain function and improve your quality of life.
      </p>
    </div>
  </section>

  <!-- Services overview -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy text-center mb-4">What We Treat</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        Our center offers a wide range of non-invasive treatments and pain management services.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Neuropathy & Nerve Pain',
          'Back Pain',
          'Knee Pain',
          'Neck Pain',
          'Joint Pain',
          'Sciatica',
          'Chronic Pain Management',
          'Regenerative Therapy',
          'Medical Weight Loss',
        ].map((item) => (
          <div class="bg-white rounded-lg px-5 py-4 flex items-center gap-3 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-brand-blue flex-shrink-0"></span>
            <span class="text-brand-navy font-medium">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Our Location</h2>
        <p class="text-gray-600 mb-2"><strong>Morningstar Neuropathy & Pain Treatment Center</strong></p>
        <p class="text-gray-600 mb-1">4710 Mexico Rd Suite C</p>
        <p class="text-gray-600 mb-1">St. Peters, MO 63376</p>
        <p class="text-gray-600 mb-6">
          Phone: <a href="tel:6362440124" class="text-brand-blue hover:underline">(636) 244-0124</a>
        </p>
        <p class="text-gray-600">
          We serve patients across a 50-mile radius including St. Louis, O'Fallon, Saint Charles, Florissant, Chesterfield, Wildwood, Wentzville, and the surrounding communities of Missouri and Illinois.
        </p>
      </div>
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Service Area</h2>
        <p class="text-gray-600 mb-4">Communities we serve include:</p>
        <div class="grid grid-cols-2 gap-2">
          {[
            'St. Louis', 'O\'Fallon', 'Saint Charles', 'Florissant',
            'Chesterfield', 'Wildwood', 'Wentzville', 'University City',
            'Ballwin', 'Granite City', 'Kirkwood', 'Maryland Heights',
          ].map((city) => (
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-blue flex-shrink-0"></span>
              {city}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-blue-200 mb-8">
        Schedule an appointment today and take the first step toward a pain-free life.
      </p>
      <a href="/schedule-appointment" class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Schedule Appointment
      </a>
    </div>
  </section>
</BaseLayout>
