---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Morningstar RegMed for regulatory consulting inquiries.">
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Contact Us</h1>
      <p class="text-xl text-gray-600">We'd love to hear from you. Placeholder — content coming in Phase 2.</p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Form -->
      <div>
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Send us a message</h2>
        <form class="space-y-5" action="#" method="post">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="Your name"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="you@company.com"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="subject">Subject</label>
            <input
              id="subject"
              name="subject"
              type="text"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="How can we help?"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-blue resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div>
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Get in touch</h2>
        <div class="space-y-6 text-gray-600">
          <div>
            <h3 class="font-semibold text-brand-navy mb-1">Email</h3>
            <p class="text-sm">Placeholder — content coming in Phase 2.</p>
          </div>
          <div>
            <h3 class="font-semibold text-brand-navy mb-1">Phone</h3>
            <p class="text-sm">Placeholder — content coming in Phase 2.</p>
          </div>
          <div>
            <h3 class="font-semibold text-brand-navy mb-1">Location</h3>
            <p class="text-sm">Placeholder — content coming in Phase 2.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
