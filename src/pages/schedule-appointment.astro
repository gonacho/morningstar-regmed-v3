---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Schedule an Appointment"
  description="Schedule your appointment at Morning Star in St. Peters, MO. Take the first step toward neuropathy relief and pain management. Call (636) 244-0124."
>
  <!-- Hero -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-muted to-primary/30"></div>
    <div class="relative section-container">
      <span class="inline-flex items-center gap-1.5 bg-accent/20 text-accent border border-accent/30 text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full mb-5">
        Free Consultation · No Obligation
      </span>
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-white mb-5 max-w-2xl">
        Schedule Your Free Consultation
      </h1>
      <p class="text-white/75 text-lg leading-relaxed max-w-xl">
        Take the first step toward lasting relief. Our team is ready to help you find the right path forward for neuropathy, chronic pain, or regenerative therapy.
      </p>
    </div>
  </section>

  <!-- Form + Side Panel -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Appointment Form -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-dark mb-6">Request an Appointment</h2>
        <form class="space-y-5" aria-label="Appointment request form">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-dark mb-1">Full Name</label>
              <input
                id="name"
                name="name"
                type="text"
                autocomplete="name"
                required
                class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="Jane Smith"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-dark mb-1">Phone Number</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                required
                class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="(636) 555-0100"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-1">Email Address</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="jane@example.com"
              />
            </div>
            <div>
              <label for="preferred-date" class="block text-sm font-medium text-dark mb-1">Preferred Date</label>
              <input
                id="preferred-date"
                name="preferred-date"
                type="date"
                class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
              />
            </div>
          </div>

          <div>
            <label for="reason" class="block text-sm font-medium text-dark mb-1">Reason for Visit</label>
            <select
              id="reason"
              name="reason"
              required
              class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 bg-white"
            >
              <option value="" disabled selected>Select a reason...</option>
              <option value="neuropathy">Neuropathy</option>
              <option value="chronic-pain">Chronic Pain</option>
              <option value="regenerative-therapy">Regenerative Therapy</option>
              <option value="weight-loss">Weight Loss</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Message (Optional)</label>
            <textarea
              id="message"
              name="message"
              rows={4}
              class="w-full border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 resize-none"
              placeholder="Tell us more about your condition or any questions you have..."
            />
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3.5 bg-accent hover:bg-accent-dark text-white font-heading font-semibold rounded-full transition-all duration-200 shadow-md"
          >
            Request Appointment
          </button>
        </form>
      </div>

      <!-- Side Panel -->
      <div class="space-y-6">
        <div class="bg-bg-warm rounded-2xl p-6">
          <h3 class="text-lg font-bold text-dark mb-3">Call Us Directly</h3>
          <a
            href="tel:+16362440124"
            class="text-2xl font-bold text-primary hover:underline"
          >
            (636) 244-0124
          </a>
          <p class="text-body text-sm mt-2">
            Our scheduling team is happy to assist you over the phone.
          </p>
        </div>

        <div class="bg-bg-warm rounded-2xl p-6">
          <h3 class="text-lg font-bold text-dark mb-3">Our Location</h3>
          <p class="text-body text-sm">
            4710 Mexico Rd Suite C<br />
            St. Peters, MO 63376
          </p>
        </div>

        <div class="bg-bg-warm rounded-2xl p-6">
          <h3 class="text-lg font-bold text-dark mb-3">Office Hours</h3>
          <ul class="text-body text-sm space-y-1">
            <li>Monday: 9:00 AM &ndash; 5:00 PM</li>
            <li>Tuesday: 9:00 AM &ndash; 5:00 PM</li>
            <li>Wednesday: 9:00 AM &ndash; 5:00 PM</li>
            <li>Thursday: 9:00 AM &ndash; 5:00 PM</li>
            <li>Friday &ndash; Sunday: Closed</li>
          </ul>
        </div>

        <div class="border border-primary/30 bg-primary/10 rounded-2xl p-6">
          <p class="text-dark text-sm font-medium">
            New patients welcome. Most consultations take about 30 minutes.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
