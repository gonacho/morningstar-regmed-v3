---
const year = new Date().getFullYear();
---

<footer class="bg-dark text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="font-heading font-700 text-xl text-white mb-3">Morning Star</h3>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Neuropathy & Pain Treatment Center serving St. Peters, MO and the greater St. Louis region.
        </p>
        <a href="tel:+16362440124" class="text-accent font-heading font-600 hover:text-accent-dark transition-colors">
          (636) 244-0124
        </a>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-heading font-600 text-xs uppercase tracking-widest mb-3 text-accent">Services</h4>
        <ul class="space-y-2">
          {[
            { href: '/pain-management/neuropathy-treatment/', label: 'Neuropathy Treatment' },
            { href: '/pain-management/chronic-pain-management/', label: 'Chronic Pain Management' },
            { href: '/pain-management/neuromodulation-technique/', label: 'Neuromodulation' },
            { href: '/regenerative-medicine/regenerative-therapy/', label: 'Regenerative Therapy' },
            { href: '/regenerative-medicine/platelet-rich-plasma-therapy/', label: 'PRP Therapy' },
            { href: '/regenerative-medicine/hyaluronic-acid-injections/', label: 'HA Injections' },
            { href: '/medical-weight-loss/', label: 'Medical Weight Loss' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/60 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Conditions -->
      <div>
        <h4 class="font-heading font-600 text-xs uppercase tracking-widest mb-3 text-accent">Conditions</h4>
        <ul class="space-y-2">
          {[
            { href: '/conditions/neuropathy/', label: 'Neuropathy' },
            { href: '/conditions/back-pain/', label: 'Back Pain' },
            { href: '/conditions/knee-pain/', label: 'Knee Pain' },
            { href: '/conditions/neck-pain/', label: 'Neck Pain' },
            { href: '/conditions/joint-pain/', label: 'Joint Pain' },
            { href: '/conditions/sciatica/', label: 'Sciatica' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/60 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
          <li><a href="/conditions/" class="text-accent/80 hover:text-accent text-sm font-500 transition-colors">All Conditions →</a></li>
        </ul>
      </div>

      <!-- Contact & Navigation -->
      <div>
        <h4 class="font-heading font-600 text-xs uppercase tracking-widest mb-3 text-accent">Visit Us</h4>
        <ul class="space-y-2 text-white/60 text-sm mb-4">
          <li>4710 Mexico Rd, Suite C<br />St. Peters, MO 63376</li>
          <li>Mon–Thu: 8am – 5pm</li>
          <li>
            <a href="/schedule-appointment/" class="text-white font-500 hover:text-accent transition-colors">
              Schedule Free Consultation →
            </a>
          </li>
        </ul>
        <ul class="space-y-1">
          <li><a href="/about/" class="text-white/60 hover:text-white text-sm transition-colors">About</a></li>
          <li><a href="/new-patients/" class="text-white/60 hover:text-white text-sm transition-colors">New Patients</a></li>
          <li><a href="/insurance/" class="text-white/60 hover:text-white text-sm transition-colors">Insurance</a></li>
          <li><a href="/blog/" class="text-white/60 hover:text-white text-sm transition-colors">Blog</a></li>
          <li><a href="/contact/" class="text-white/60 hover:text-white text-sm transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-white/40 text-xs">
      <span>&copy; {year} Morning Star Neuropathy & Pain Treatment Center. All rights reserved.</span>
      <div class="flex gap-4">
        <a href="/privacy-policy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms-of-service/" class="hover:text-white transition-colors">Terms of Service</a>
        <span class="text-white/30">HIPAA Compliant</span>
      </div>
    </div>
  </div>
</footer>
