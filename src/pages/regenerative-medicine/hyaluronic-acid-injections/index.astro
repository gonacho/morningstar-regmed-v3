---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Hyaluronic Acid Injections in St. Peters, MO | Morning Star';
const description =
  'Relieve joint pain with hyaluronic acid injections at Morning Star in St. Peters, MO. Minimally invasive joint lubrication for improved mobility.';

const faqs = [
  {
    question: 'Do hyaluronic acid injections actually work?',
    answer:
      'Effectiveness depends on the severity of your joint condition. Most patients with mild to moderate osteoarthritis experience meaningful relief, including reduced pain, improved mobility, and better joint function. For advanced joint degeneration, results may be more limited. Our team will assess your condition and discuss realistic expectations during your consultation.',
  },
  {
    question: 'How long do the results last?',
    answer:
      'Results typically last between 4 to 6 months, though some patients experience relief for up to a year. The duration varies based on the severity of your condition, the joint treated, and your activity level. Repeat injections can be administered to maintain the benefits over time.',
  },
  {
    question: 'Who should not get hyaluronic acid injections?',
    answer:
      'Patients with bleeding disorders, certain allergies (particularly to hyaluronic acid or avian products, depending on the formulation), or an active infection in or around the joint should not receive these injections. Our clinical team reviews your full medical history before recommending treatment to ensure your safety.',
  },
  {
    question: 'What should I expect during the procedure?',
    answer:
      'The procedure is straightforward and performed in-office. After cleaning the injection site, a local anesthetic may be applied to minimize discomfort. The hyaluronic acid is then injected directly into the joint. The entire process typically takes 15 to 30 minutes, and most patients return to normal activities the same day.',
  },
  {
    question: 'What is the recovery time?',
    answer:
      'Recovery is minimal. You may experience mild swelling or stiffness at the injection site for 24 to 48 hours. We recommend avoiding strenuous activity for a day or two after treatment. Most patients resume their daily routine immediately and notice progressive improvement over the following weeks.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalWebPage',
      name: title,
      description: description,
      url: 'https://morningstarregmed.com/regenerative-medicine/hyaluronic-acid-injections/',
      isPartOf: {
        '@type': 'WebSite',
        name: 'Morning Star Neuropathy & Pain Treatment Center',
        url: 'https://morningstarregmed.com/',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://morningstarregmed.com/' },
          { '@type': 'ListItem', position: 2, name: 'Regenerative Medicine', item: 'https://morningstarregmed.com/regenerative-medicine/' },
          { '@type': 'ListItem', position: 3, name: 'Hyaluronic Acid Injections' },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ question, answer }) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: { '@type': 'Answer', text: answer },
      })),
    },
  ],
});
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-gray-500" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-brand-blue">Home</a></li>
      <li>/</li>
      <li><a href="/regenerative-medicine/" class="hover:text-brand-blue">Regenerative Medicine</a></li>
      <li>/</li>
      <li class="text-brand-navy font-medium">Hyaluronic Acid Injections</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Hyaluronic Acid Injections in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Minimally invasive <b>joint lubrication therapy</b> designed to relieve pain, reduce stiffness, and restore mobility, without surgery or heavy medication.
      </p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">What Are Hyaluronic Acid Injections?</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        <b>Hyaluronic acid</b> is a naturally occurring substance found in joint fluid that acts as a lubricant and shock absorber. When joints become damaged or arthritic, hyaluronic acid levels decrease, leading to increased friction, stiffness, and pain. Hyaluronic acid injections replenish this vital fluid, restoring cushioning and improving joint function.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        At <b>Morning Star Neuropathy &amp; Pain Treatment Center</b>, this minimally invasive treatment offers a faster recovery path compared to surgery, without the side effects of long-term medication use. It is especially effective for patients with mild to moderate joint conditions who want to maintain an active lifestyle.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Hyaluronic acid injections are part of our <a href="/regenerative-medicine/" class="text-brand-blue underline hover:text-blue-700">regenerative medicine</a> program in St. Peters. We also offer <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-brand-blue underline hover:text-blue-700">platelet-rich plasma (PRP) therapy</a> and <a href="/regenerative-medicine/regenerative-therapy/" class="text-brand-blue underline hover:text-blue-700">exosome-based regenerative therapy</a> for patients who need a different approach or combination of treatments.
      </p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">How the Treatment Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">1. Joint Assessment</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            We evaluate the affected joint through physical examination and imaging to determine the degree of cartilage loss and confirm that hyaluronic acid injections are appropriate.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">2. Precision Injection</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            Hyaluronic acid is injected directly into the joint space using guided techniques. A local anesthetic is applied to ensure comfort throughout the brief procedure.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="text-brand-blue font-bold text-lg mb-2">3. Progressive Relief</div>
          <p class="text-gray-600 text-sm leading-relaxed">
            As the hyaluronic acid restores joint lubrication, patients typically notice reduced pain and improved mobility over the following weeks. Follow-up visits track your progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Conditions Treated -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Who Benefits from Hyaluronic Acid Injections?</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        This treatment is most effective for patients experiencing joint pain from cartilage wear or early-stage arthritis. Patients visit our St. Peters office for hyaluronic acid injections to address:
      </p>
      <ul class="grid md:grid-cols-2 gap-3 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600"><a href="/conditions/knee-pain/" class="text-brand-blue underline hover:text-blue-700">Knee pain</a> from osteoarthritis or cartilage loss</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600"><a href="/conditions/joint-pain/" class="text-brand-blue underline hover:text-blue-700">Joint pain</a> in hips, shoulders, and ankles</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Stiffness that limits daily movement or activity</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Mild to moderate osteoarthritis</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Joint discomfort that has not improved with oral medication</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Patients who want to delay or avoid joint replacement surgery</span>
        </li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        During your consultation, our team will review your medical history and imaging to confirm whether hyaluronic acid injections are the right choice for your specific condition.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">Benefits of Hyaluronic Acid Injections</h2>
      <ul class="grid md:grid-cols-2 gap-4">
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Restores natural joint lubrication</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Reduces pain and stiffness without surgery</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Minimally invasive, in-office procedure</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Results lasting 4 to 6 months or longer</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">No heavy medication side effects</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-0.5">&#10003;</span>
          <span class="text-gray-600">Effective for mild to moderate osteoarthritis</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">What Our Patients Say</h2>
      <blockquote class="bg-white rounded-xl p-8 border border-gray-200 shadow-sm">
        <p class="text-gray-600 leading-relaxed italic mb-4">
          "I have had two separate rounds of treatment done with the team at Morningstar. First, I had hyaluronic acid gel injections done on my knee. My pain went from an 8/10 to at most a 2/10. Great success if you ask me! Kay's bedside manner is absolutely wonderful and the admin staff made me feel welcomed and stress-free. After I finished with my knee, I did PRP treatments to both of my shoulders. My shoulders have been very weak and causing me a lot of pain due to what I do for a living, and this has been the only thing to help so far. Definitely helped me avoid shoulder surgery and now my pain is maybe a 2/10 on a bad day! These people work absolute miracles for non-invasive pain management options, and I recommend them hands down to anyone looking for relief! 5 stars!"
        </p>
        <footer class="text-brand-navy font-semibold">
          John B.
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Why Morning Star -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Why Choose Morning Star for Joint Injections?</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Morning Star Neuropathy &amp; Pain Treatment Center focuses on non-surgical pain relief that fits your life. Hyaluronic acid injections are one of the most straightforward treatments we offer, with most sessions taking 15 to 30 minutes. You can walk in, receive treatment, and return to your day.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        Our team does not recommend treatments you do not need. Every patient receives a thorough evaluation before we suggest a course of action. Located at 4710 Mexico Rd Suite C in St. Peters, MO, our clinic provides a comfortable, low-stress environment for your care.
      </p>
      <p class="text-gray-600 leading-relaxed">
        For patients whose joint damage requires a more targeted regenerative approach, we may suggest <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-brand-blue underline hover:text-blue-700">PRP therapy</a> or <a href="/regenerative-medicine/regenerative-therapy/" class="text-brand-blue underline hover:text-blue-700">exosome-based regenerative therapy</a> as an alternative or complement to hyaluronic acid injections.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Move Freely Again</h2>
      <p class="text-blue-200 mb-8">
        Contact Morning Star at <a href="tel:+16362440124" class="text-white underline hover:text-blue-100">(636) 244-0124</a> to find out if hyaluronic acid injections can help restore comfort and mobility to your joints.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
