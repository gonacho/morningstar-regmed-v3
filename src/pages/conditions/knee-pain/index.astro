---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalConditionSchema from '@/components/schemas/MedicalConditionSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Knee Pain Treatment in St. Peters, MO | Morning Star';
const description =
  'Knee pain treatment at Morning Star in St. Peters, MO. Expert care for meniscus tears, arthritis, and chronic knee conditions without surgery.';

const faqs = [
  {
    question: 'What are the most common causes of knee pain?',
    answer:
      'The most common causes of knee pain include osteoarthritis, meniscus tears, ligament injuries (such as ACL and MCL tears), tendinitis, bursitis, and overuse from repetitive activities. Excess body weight also places additional stress on the knee joints, accelerating cartilage breakdown and joint deterioration over time.',
  },
  {
    question: 'When should I see a doctor for knee pain?',
    answer:
      'You should see a doctor if your knee pain lasts beyond one week, as this usually indicates a larger underlying issue. Seek immediate care if you heard a popping sound at the time of injury, cannot bear weight on the knee, experience significant swelling, or notice the knee locking or giving way during movement.',
  },
  {
    question: 'What treatment options are available for knee pain?',
    answer:
      'Morning Star offers multiple non-surgical treatment options for knee pain, including hyaluronic acid injections to restore joint lubrication, platelet-rich plasma (PRP) therapy to promote tissue repair, regenerative therapy to support natural healing, and comprehensive pain management programs tailored to each patient.',
  },
  {
    question: 'Can knee pain be prevented?',
    answer:
      'Many knee problems can be prevented or delayed by maintaining a healthy weight, strengthening the muscles that support the knee (especially the quadriceps and hamstrings), using proper form during exercise, wearing supportive footwear, and warming up before physical activity. Low-impact exercises like swimming and cycling are excellent for long-term knee health.',
  },
  {
    question: 'What age group is most affected by knee pain?',
    answer:
      'Knee pain reaches its peak prevalence between ages 55 and 64, primarily due to osteoarthritis and accumulated wear on the joint. However, knee pain can occur at any age. Younger adults frequently experience knee injuries from sports and high-impact activities, while middle-aged adults may develop pain from overuse or early-stage arthritis.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalConditionSchema
      id="condition-knee-pain"
      name="Knee Pain"
      description="Knee pain from arthritis, injury, or degeneration affects daily mobility. Discover non-surgical treatment options available in St. Peters, MO."
      url="https://morningstarregmed.com/conditions/knee-pain/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      possibleTreatments={["service-platelet-rich-plasma-therapy","service-hyaluronic-acid-injections","service-regenerative-therapy"]}
      causes={["Osteoarthritis","Meniscus tear","Ligament injury","Bursitis","Patellar tendinitis"]}
      signOrSymptom={["Joint pain","Swelling","Stiffness","Reduced range of motion","Clicking or popping"]}
      associatedAnatomy="Knee joint"
      riskFactor={["Overweight","Age over 45","Prior knee injury","Repetitive stress activities"]}
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/conditions/knee-pain/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#condition-knee-pain"
      aspect="Symptom"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Conditions","url":"https://morningstarregmed.com/conditions/"},{"name":"Knee Pain","url":"https://morningstarregmed.com/conditions/knee-pain/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Hero -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-white mb-5">Knee Pain Treatment in St.&nbsp;Peters, MO</h1>
      <p class="text-white/80 text-lg leading-relaxed">
        Knee pain can limit your mobility and keep you from the activities you love. At Morning Star
        Neuropathy &amp; Pain Treatment Center in St.&nbsp;Peters, MO, we provide expert diagnosis and
        non-surgical treatment options designed to help you get back on your feet, without invasive
        procedures or lengthy recovery times.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 btn-primary inline-flex"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Understanding Knee Pain -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Understanding Knee Pain</h2>
      <p class="text-body mb-4 leading-relaxed">
        <strong>Knee pain</strong> is one of the most common musculoskeletal complaints in the United
        States, with peak prevalence occurring between ages 55 and 64. The knee joint bears the full
        weight of the body during standing, walking, running, and climbing, making it especially
        vulnerable to injury and wear.
      </p>
      <p class="text-body mb-4 leading-relaxed">
        Meniscus tears are among the most frequent knee injuries. The meniscus is a C-shaped piece of
        cartilage that cushions the space between your shinbone and thighbone. When it tears, you may
        experience a popping sensation followed by swelling, stiffness, and pain, especially when
        twisting or rotating the knee. Left untreated, a torn meniscus can accelerate joint
        deterioration and lead to chronic knee problems.
      </p>
      <p class="text-body leading-relaxed">
        Orthotics such as knee braces provide support and stability, though they are most effective as
        part of a comprehensive treatment plan. Pain that persists beyond one week typically indicates
        a larger issue requiring professional evaluation.
      </p>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Common Causes of Knee Pain</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Meniscus Tears</h3>
          <p class="text-body text-sm leading-relaxed">
            Tears in the cartilage cushion of the knee, often caused by sudden twisting or rotating
            movements. Symptoms include popping sensations, swelling, and pain during movement.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Osteoarthritis</h3>
          <p class="text-body text-sm leading-relaxed">
            Progressive <strong>cartilage deterioration</strong> in the knee joint causes bones to
            grind against each other, resulting in pain, stiffness, and reduced mobility. This is the
            most common form of arthritis affecting the knee.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Ligament Injuries</h3>
          <p class="text-body text-sm leading-relaxed">
            ACL, MCL, and other ligament tears or sprains commonly occur during sports or sudden
            directional changes, causing instability and significant pain.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Overuse and Tendinitis</h3>
          <p class="text-body text-sm leading-relaxed">
            Repetitive stress from running, jumping, or climbing stairs can inflame the tendons around
            the knee, leading to chronic discomfort and reduced function.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Symptoms to Watch For</h2>
      <p class="text-body mb-6 leading-relaxed">
        Knee pain presents differently depending on the underlying cause. Pay close attention to these
        warning signs:
      </p>
      <ul class="space-y-3 text-body">
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Popping or clicking sounds during movement</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Swelling and stiffness in or around the knee</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain when twisting, rotating, or bending the knee</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Difficulty straightening the knee fully</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> The knee locking or giving way unexpectedly</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain that worsens with stairs, squatting, or kneeling</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Warmth or redness around the joint</li>
      </ul>
    </div>
  </section>

  <!-- Treatment Options at Morning Star -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Treatment Options at Morning Star</h2>
      <p class="text-body mb-6 leading-relaxed">
        Our non-surgical approach to <strong>knee pain treatment</strong> focuses on reducing
        inflammation, promoting natural healing, and restoring function. Your personalized plan may
        include one or more of the following therapies.
      </p>

      <div class="space-y-4">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Platelet-Rich Plasma (PRP) Therapy</h3>
          <p class="text-body text-sm leading-relaxed">
            <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-primary underline hover:text-primary-dark">PRP therapy</a>
            uses growth factors concentrated from your own blood to accelerate tissue repair and
            reduce inflammation in the knee joint. This treatment is especially effective for soft
            tissue injuries and early-stage arthritis.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Hyaluronic Acid Injections</h3>
          <p class="text-body text-sm leading-relaxed">
            <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary underline hover:text-primary-dark">Hyaluronic acid injections</a>
            restore the natural lubrication in your knee joint, reducing bone-on-bone friction and
            providing significant pain relief for patients with osteoarthritis.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Regenerative Therapy</h3>
          <p class="text-body text-sm leading-relaxed">
            Our <a href="/regenerative-medicine/regenerative-therapy/" class="text-primary underline hover:text-primary-dark">regenerative therapy</a>
            program supports the body's natural healing processes, helping to repair damaged cartilage
            and joint tissue without surgery. Many patients see meaningful improvement within weeks
            of starting treatment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-8">What Our Patients Say</h2>
      <div class="bg-bg-cream rounded-2xl p-6 border border-border">
        <p class="text-body leading-relaxed mb-3 italic">
          "I have had two separate rounds of treatment done with the team at Morningstar. First, I had hyaluronic acid gel injections done on my knee. My pain went from an 8/10 to at most a 2/10. Great success if you ask me! Kay's bedside manner is absolutely wonderful and the admin staff made me feel welcomed and stress-free. After I finished with my knee, I did PRP treatments to both of my shoulders. My shoulders have been very weak and causing me a lot of pain due to what I do for a living, and this has been the only thing to help so far. Definitely helped me avoid shoulder surgery and now my pain is maybe a 2/10 on a bad day! These people work absolute miracles for non-invasive pain management options, and I recommend them hands down to anyone looking for relief! 5 stars!"
        </p>
        <p class="font-semibold text-dark text-sm">John Brantley</p>
      </div>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">When to Seek Professional Help</h2>
      <p class="text-body mb-4 leading-relaxed">
        Knee pain that lasts beyond one week usually signals a condition that needs professional
        attention. You should schedule an evaluation at our St.&nbsp;Peters clinic if:
      </p>
      <ul class="space-y-2 text-body mb-6">
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain persists for more than one week despite rest</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> You cannot bear weight on the affected knee</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> The knee is visibly swollen, red, or warm to the touch</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> You heard a popping sound at the time of injury</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> The knee feels unstable or locks during movement</li>
      </ul>
      <p class="text-body leading-relaxed">
        Call Morning Star at
        <a href="tel:+16362440124" class="text-primary underline hover:text-primary-dark">(636) 244-0124</a>
        to schedule your evaluation.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-2xl p-6 border border-border">
            <dt class="font-semibold text-dark mb-2">{question}</dt>
            <dd class="text-body text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Get Back on Your Feet</h2>
      <p class="text-white/70 mb-8">
        Do not let knee pain keep you sidelined. Contact Morning Star Neuropathy &amp; Pain Treatment
        Center in St.&nbsp;Peters, MO today to schedule your evaluation and start your recovery.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact-us/"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white hover:text-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
