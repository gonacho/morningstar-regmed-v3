---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OrganizationSchema from '@/components/schemas/OrganizationSchema.astro';
import LocalBusinessSchema from '@/components/schemas/LocalBusinessSchema.astro';
import WebSiteSchema from '@/components/schemas/WebSiteSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const SITE_URL = 'https://morningstarregmed.com';
const title = 'Neuropathy & Pain Treatment in St. Peters, MO | Morning Star';
const description =
  'Morning Star provides advanced neuropathy treatment, regenerative therapy, and pain management in St. Peters, MO. Non-surgical relief. Call (636) 244-0124.';

const faqs = [
  {
    question: 'What conditions does Morning Star treat?',
    answer:
      'Morning Star treats peripheral neuropathy, chronic pain, knee pain, back pain, neck pain, joint pain, and sciatica using non-surgical approaches including neuromodulation, regenerative therapy, PRP, and hyaluronic acid injections.',
  },
  {
    question: 'Where is Morning Star located?',
    answer:
      'Morning Star Neuropathy & Pain Treatment Center is located at 4710 Mexico Rd Suite C, St. Peters, MO 63376. We serve patients throughout St. Charles County and the greater St. Louis metropolitan area.',
  },
  {
    question: "What are Morning Star's office hours?",
    answer:
      'Morning Star is open Monday through Thursday, 8am to 5pm. Call (636) 244-0124 or schedule online at any time.',
  },
  {
    question: 'Does Morning Star accept insurance?',
    answer:
      'Morning Star accepts major medical insurance. We also offer CareCredit financing. Contact our office for details about your specific plan.',
  },
];

const services = [
  { href: '/pain-management/neuropathy-treatment/', title: 'Neuropathy Treatment', body: 'Advanced non-surgical solutions for peripheral neuropathy pain, numbness, and tingling.', img: '/images/pain-management/neuropathy-treatment-st-peters-mo.webp' },
  { href: '/pain-management/chronic-pain-management/', title: 'Chronic Pain Management', body: 'Personalized plans combining regenerative, neuromodulation, and lifestyle therapies.', img: '/images/pain-management/chronic-pain-management-st-peters-mo.webp' },
  { href: '/pain-management/neuromodulation-technique/', title: 'Neuromodulation Technique', body: 'Electrical stimulation that restores nerve function without medication or surgery.', img: '/images/pain-management/neuromodulation-technique-st-peters-mo.webp' },
  { href: '/regenerative-medicine/regenerative-therapy/', title: 'Regenerative Therapy', body: 'Exosome-based treatments that reduce inflammation and support cellular repair.', img: '/images/regenerative-medicine/regenerative-therapy-st-peters-mo.webp' },
  { href: '/regenerative-medicine/platelet-rich-plasma-therapy/', title: 'PRP Therapy', body: "Harness your body's own healing factors to accelerate recovery in joints and tissues.", img: '/images/regenerative-medicine/platelet-rich-plasma-therapy-st-peters-mo.webp' },
  { href: '/medical-weight-loss/', title: 'Medical Weight Loss', body: 'Clinically supervised semaglutide and tirzepatide programs for lasting results.', img: '/images/medical-weight-loss/medical-weight-loss-st-peters-mo.webp' },
];

const testimonials = [
  { quote: 'The people working here are fantastic. The treatments were just fantastic. I am 100% very very happy with everything. Thank you so very much.', name: 'Clyde S.', location: 'St. Peters, MO', condition: 'Pain Patient' },
  { quote: 'I went from arriving in a wheelchair to walking with a cane! Marvelous improvement from not being able to walk at all. I owe all this to the wonderful staff of Morningstar.', name: 'Brenda L.', location: 'St. Peters, MO', condition: 'Neuropathy Patient' },
  { quote: "I had neuropathy in my feet and now it's about gone with the treatment they're giving me. They know what they're doing. This is a very good place if you have neuropathy.", name: 'Arthur B.', location: 'St. Charles, MO', condition: 'Neuropathy Patient' },
];

const steps = [
  { num: '01', title: 'Free Consultation', body: 'Meet with our specialists to discuss your symptoms, medical history, and treatment goals — no obligation.' },
  { num: '02', title: 'Comprehensive Evaluation', body: 'We run diagnostic tests to understand the root cause of your pain and identify the best treatment path.' },
  { num: '03', title: 'Personalized Treatment Plan', body: 'Your customized plan combines the therapies most effective for your specific condition and lifestyle.' },
  { num: '04', title: 'Ongoing Support', body: 'We track your progress at every visit and adjust your plan to ensure you keep improving.' },
];

const breadcrumbItems = [{ name: 'Home', url: SITE_URL }];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <OrganizationSchema />
    <LocalBusinessSchema includeReviews={true} />
    <WebSiteSchema />
    <MedicalWebPageSchema
      url={SITE_URL}
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2026-05-21"
      mainEntityId={`${SITE_URL}/#localbusiness`}
    />
    <BreadcrumbSchema items={breadcrumbItems} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <img src="/images/homepage/medical-clinic-st-peters-mo-hero.webp" alt="Morning Star clinic — warm, welcoming care in St. Peters" fetchpriority="high" loading="eager" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/55 to-transparent"></div>
    <div class="relative section-container py-24 lg:py-32">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-1.5 bg-accent/20 text-accent border border-accent/30 text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full mb-6">
          ✦ Trusted Since 2009 · St. Peters, MO
        </span>
        <h1 class="font-heading font-bold text-5xl lg:text-6xl text-white leading-tight mb-5">
          Natural Pain Relief That <span class="text-accent">Actually Works</span>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          Advanced neuropathy and regenerative medicine — non-surgical, science-backed, patient-first. Serving St. Peters and greater St. Louis.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a href="/schedule-appointment/" class="btn-primary">Book Free Consultation →</a>
          <a href="/pain-management/" class="btn-ghost">See Our Treatments</a>
        </div>
        <div class="flex flex-wrap gap-x-5 gap-y-2 text-white/70 text-sm">
          <span>⭐ 4.9 Google Rating</span>
          <span class="text-white/30">·</span>
          <span>✓ Accepting New Patients</span>
          <span class="text-white/30">·</span>
          <a href="tel:+16362440124" class="hover:text-white transition-colors">📞 (636) 244-0124</a>
        </div>
      </div>
    </div>
    <!-- Floating appointment card (desktop) -->
    <div class="hidden lg:block absolute bottom-10 right-10 bg-white rounded-2xl p-5 shadow-xl border border-accent/30 w-52">
      <p class="font-heading font-semibold text-dark text-sm mb-1">Office Hours</p>
      <p class="text-body text-xs leading-relaxed mb-3">Mon–Thu<br/>8:00 am – 5:00 pm</p>
      <a href="/schedule-appointment/" class="block w-full text-center bg-accent hover:bg-accent-dark text-white text-xs font-heading font-semibold py-2 rounded-full transition-colors">Book Appointment</a>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-white border-y border-border">
    <div class="section-container py-4">
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-body text-sm">
        <span><span class="text-accent font-bold">15+</span> Years Experience</span>
        <span class="text-border hidden sm:inline">|</span>
        <span><span class="text-accent font-bold">12</span> Conditions Treated</span>
        <span class="text-border hidden sm:inline">|</span>
        <span><span class="text-accent font-bold">2,500+</span> Five-Star Reviews</span>
        <span class="text-border hidden sm:inline">|</span>
        <span><span class="text-accent font-bold">✓</span> Insurance Accepted</span>
      </div>
    </div>
  </section>

  <!-- ABOUT / WHO WE ARE -->
  <section class="bg-bg-warm section-padding">
    <div class="section-container">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div class="relative">
          <img src="/images/about/about-morning-star-st-peters-mo.webp" alt="Morning Star clinic exterior in St. Peters, MO" class="rounded-2xl w-full object-cover aspect-[4/3] shadow-lg" />
          <div class="absolute -bottom-6 -right-6 w-40 h-40 rounded-2xl overflow-hidden border-4 border-white shadow-xl hidden sm:block">
            <img src="/images/new-patients/new-patients-st-peters-mo.webp" alt="Morning Star welcoming reception" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -top-4 -left-4 bg-accent text-white rounded-2xl px-4 py-3 shadow-xl hidden sm:block">
            <p class="font-heading font-bold text-lg leading-none">15+</p>
            <p class="text-xs text-white/80 mt-0.5">Years Trusted Care</p>
          </div>
        </div>
        <div>
          <span class="inline-flex items-center gap-1.5 bg-primary/10 text-primary border border-primary/20 text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full mb-4">Accepting New Patients</span>
          <h2 class="font-heading font-bold text-4xl text-dark mb-5">Healing That Puts the Patient First</h2>
          <p class="text-body text-lg leading-relaxed mb-4">At Morning Star in St. Peters, MO, we believe lasting relief is possible — without surgery, without endless medications, and without feeling like just another chart number.</p>
          <p class="text-body leading-relaxed mb-6">Our team combines advanced regenerative medicine, neuromodulation, and personalized care plans to address the root cause of your pain — from chronic neuropathy to joint pain.</p>
          <div class="flex flex-wrap gap-3 mb-6">
            <span class="text-xs bg-bg-cream text-body px-3 py-1.5 rounded-full border border-border">Board Certified Specialists</span>
            <span class="text-xs bg-bg-cream text-body px-3 py-1.5 rounded-full border border-border">Non-Surgical Protocols</span>
            <span class="text-xs bg-bg-cream text-body px-3 py-1.5 rounded-full border border-border">HIPAA Compliant</span>
          </div>
          <a href="/about/" class="text-primary font-semibold hover:text-primary-dark inline-flex items-center gap-1 transition-colors">Meet the Team →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="bg-white section-padding">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-4xl text-dark mb-3">Our Treatments</h2>
        <p class="text-body text-lg max-w-2xl mx-auto">Non-surgical, science-backed therapies designed to address the root cause of your pain.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(({ href, title: sTitle, body, img }) => (
          <a href={href} class="bg-white rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 group">
            <div class="aspect-video overflow-hidden">
              <img src={img} alt={sTitle} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <h3 class="font-heading font-semibold text-xl text-dark mb-2">{sTitle}</h3>
              <p class="text-body text-sm leading-relaxed mb-4">{body}</p>
              <span class="text-primary font-medium text-sm inline-flex items-center gap-1">Learn more →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/pain-management/" class="btn-secondary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- STATS COUNTER (dark section) -->
  <section class="bg-dark section-padding">
    <div class="section-container">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-white/10">
        <div class="text-center px-4">
          <p class="font-heading font-bold text-5xl text-accent" data-counter="2500" data-suffix="+">2,500+</p>
          <p class="text-white/70 text-sm mt-2">Patients Treated</p>
        </div>
        <div class="text-center px-4">
          <p class="font-heading font-bold text-5xl text-accent" data-counter="15" data-suffix="+">15+</p>
          <p class="text-white/70 text-sm mt-2">Years Experience</p>
        </div>
        <div class="text-center px-4">
          <p class="font-heading font-bold text-5xl text-accent" data-counter="12" data-suffix="">12</p>
          <p class="text-white/70 text-sm mt-2">Conditions Treated</p>
        </div>
        <div class="text-center px-4">
          <p class="font-heading font-bold text-5xl text-accent">4.9 ★</p>
          <p class="text-white/70 text-sm mt-2">Google Rating</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PATIENT JOURNEY / HOW IT WORKS -->
  <section class="bg-bg-cream section-padding">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-4xl text-dark mb-3">Your Path to Relief</h2>
        <p class="text-body text-lg max-w-xl mx-auto">Here is what to expect from your first call to lasting results.</p>
      </div>
      <div class="max-w-2xl mx-auto space-y-8">
        {steps.map(({ num, title: sTitle, body }) => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-accent flex items-center justify-center font-heading font-bold text-white text-lg shadow-md">{num}</div>
            <div class="pt-1">
              <h3 class="font-heading font-semibold text-xl text-dark mb-1.5">{sTitle}</h3>
              <p class="text-body leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-white section-padding">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-4xl text-dark mb-3">What Our Patients Say</h2>
        <p class="text-body text-lg">Real patients. Real results. Real life — reclaimed.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(({ quote, name, location, condition }) => (
          <div class="bg-white rounded-2xl p-7 border-l-4 border-accent shadow-sm hover:shadow-md transition-shadow">
            <div class="flex gap-0.5 mb-3 text-accent text-lg">★★★★★</div>
            <blockquote class="text-body leading-relaxed mb-5 italic">"{quote}"</blockquote>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-bg-cream flex items-center justify-center font-heading font-bold text-primary text-sm flex-shrink-0">{name.charAt(0)}</div>
              <div>
                <p class="font-heading font-semibold text-dark text-sm">{name}</p>
                <p class="text-muted text-xs">{location} · {condition}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="bg-bg-warm section-padding">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="font-heading font-bold text-4xl text-dark mb-3">Meet Our Team</h2>
        <p class="text-body text-lg">Compassionate specialists dedicated to your recovery.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { name: 'Dr. Bradley Smith', role: 'Pain Management Specialist', img: 'https://picsum.photos/seed/doctor1/400/533', bio: '15+ years in regenerative medicine and neuromodulation for chronic pain.' },
          { name: 'Heather Jones, RN', role: 'Lead Treatment Nurse', img: 'https://picsum.photos/seed/nurse1/400/533', bio: 'Specializes in neuropathy protocols and patient education and support.' },
          { name: 'Mandy Williams', role: 'Patient Care Coordinator', img: 'https://picsum.photos/seed/staff1/400/533', bio: 'Guides new patients through their treatment journey from first call to discharge.' },
        ].map(({ name, role, img, bio }) => (
          <div class="relative rounded-2xl overflow-hidden group shadow-sm hover:shadow-md transition-shadow">
            <img src={img} alt={name} data-placeholder="true" class="w-full aspect-[3/4] object-cover" />
            <div class="absolute inset-0 bg-dark/85 flex flex-col justify-end p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
              <h3 class="font-heading font-bold text-white text-xl">{name}</h3>
              <p class="text-accent text-sm mt-0.5 mb-3">{role}</p>
              <p class="text-white/70 text-sm leading-relaxed">{bio}</p>
            </div>
            <div class="absolute bottom-0 left-0 right-0 bg-white px-5 py-3 translate-y-0 group-hover:translate-y-full transition-transform duration-300">
              <p class="font-heading font-semibold text-dark">{name}</p>
              <p class="text-muted text-sm">{role}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/about/" class="btn-secondary">Meet the Full Team</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bg-cream section-padding">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading font-bold text-3xl text-dark text-center mb-10">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map(({ question, answer }) => (
            <details class="bg-white rounded-2xl border border-border group shadow-sm">
              <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-heading font-semibold text-dark list-none">
                {question}
                <svg class="w-5 h-5 text-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-body text-sm leading-relaxed">{answer}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BLOCK -->
  <section class="bg-primary py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl text-white mb-4">Ready to Start Your Recovery?</h2>
      <p class="text-white/80 text-lg mb-8">Take the first step toward lasting pain relief. Consultations are free — no obligation.</p>
      <a href="/schedule-appointment/" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg">
        Schedule Free Consultation →
      </a>
      <p class="text-white/50 text-sm mt-4">📞 (636) 244-0124 · Mon–Thu 8am–5pm</p>
    </div>
  </section>
</BaseLayout>
