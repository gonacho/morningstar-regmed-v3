---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Neuropathy & Pain Management Clinic in St. Peters, MO"
  description="Morningstar Neuropathy & Pain Treatment Center — expert neuropathy and pain management in St. Peters, MO. Non-invasive treatments, no medication required."
>
  <!-- Hero -->
  <section class="bg-brand-light py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-brand-navy leading-tight mb-6">
        Neuropathy & Pain Management Clinic in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Morningstar Neuropathy & Pain Treatment Center helps you live a pain-free life through comprehensive, non-invasive treatments — no surgery, no daily medications required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/schedule-appointment" class="px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
          Schedule an Appointment
        </a>
        <a href="/contact-us" class="px-8 py-3 border-2 border-brand-navy text-brand-navy font-semibold rounded-lg hover:bg-brand-navy hover:text-white transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy text-center mb-4">Our Treatments</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        We offer a full range of non-invasive pain management and regenerative treatments tailored to your condition.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Neuropathy Treatment', href: '/neuropathy-treatment', desc: 'Customized plans to restore peripheral nerve health and relieve neuropathic pain.' },
          { title: 'Regenerative Therapy', href: '/regenerative-therapy', desc: 'Exosome-based treatments that reduce inflammation and support tissue repair.' },
          { title: 'PRP Therapy', href: '/platelet-rich-plasma-therapy', desc: 'Platelet-rich plasma that accelerates healing in joints and soft tissues.' },
          { title: 'Hyaluronic Acid Injections', href: '/hyaluronic-acid-injections', desc: 'Lubricate joints and reduce pain with minimally invasive HA injections.' },
          { title: 'Neuromodulation Technique', href: '/neuromodulation-technique', desc: 'Controlled electrical stimulation to restore nerve function and reduce pain signals.' },
          { title: 'Medical Weight Loss', href: '/medical-weight-loss', desc: 'Medically supervised weight loss using semaglutide and tirzepatide.' },
          { title: 'Back Pain', href: '/back-pain', desc: 'Identify and treat the underlying causes of your back pain for lasting relief.' },
          { title: 'Knee Pain', href: '/knee-pain', desc: 'Professional knee pain management to restore mobility and function.' },
          { title: 'Chronic Pain Management', href: '/chronic-pain-management', desc: 'Long-term strategies for managing chronic pain and improving quality of life.' },
        ].map(({ title, href, desc }) => (
          <a href={href} class="p-6 rounded-xl border border-gray-200 hover:shadow-md hover:border-brand-blue transition-all group">
            <h3 class="font-semibold text-lg text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">{title}</h3>
            <p class="text-gray-500 text-sm">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-4">Why Choose Morningstar?</h2>
        <p class="text-gray-600 mb-4">
          Located at 4710 Mexico Rd Suite C, St. Peters, MO 63376, Morningstar Neuropathy & Pain Treatment Center serves patients across a 50-mile radius — including St. Louis, O'Fallon, Saint Charles, Chesterfield, Wentzville, and surrounding communities.
        </p>
        <p class="text-gray-600 mb-6">
          Our team specializes in identifying the root cause of your pain and building a personalized treatment plan — without relying on medication or invasive procedures.
        </p>
        <a href="/about-us" class="inline-block px-6 py-2.5 bg-brand-blue text-white font-medium rounded-lg hover:bg-blue-700 transition-colors">
          Learn About Us
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { stat: 'Non-Invasive', label: 'Treatments' },
          { stat: 'No Surgery', label: 'Required' },
          { stat: '50-Mile', label: 'Service Radius' },
          { stat: 'Personalized', label: 'Care Plans' },
        ].map(({ stat, label }) => (
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="text-xl font-bold text-brand-blue mb-1">{stat}</div>
            <div class="text-sm text-gray-500">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Live Pain-Free?</h2>
      <p class="text-blue-200 mb-8">
        Schedule an appointment at our St. Peters, MO clinic. Call us at <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or book online.
      </p>
      <a href="/schedule-appointment" class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Schedule Appointment
      </a>
    </div>
  </section>
</BaseLayout>
