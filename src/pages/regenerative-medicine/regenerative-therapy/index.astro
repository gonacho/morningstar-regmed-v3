---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TherapeuticProcedureSchema from '@/components/schemas/TherapeuticProcedureSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Regenerative Therapy in St. Peters, MO | Morning Star';
const description =
  'Exosome therapy at Morning Star in St. Peters, MO harnesses your body\'s healing power. Reduce inflammation and support tissue repair.';

const faqs = [
  {
    question: 'What are the benefits of exosome therapy?',
    answer:
      'Exosome therapy can help regenerate damaged tissue, manage chronic pain, and reduce inflammation throughout the body. Exosomes carry growth factors and signaling molecules that support the body\'s natural repair processes at a cellular level, making them a powerful option for patients seeking non-surgical recovery.',
  },
  {
    question: 'Are there side effects from exosome therapy?',
    answer:
      'Side effects are typically mild and short-lived. Some patients experience minor swelling, bruising, or redness at the treatment site. These effects generally resolve within a few days. Serious complications are rare when the procedure is performed by qualified providers like our team at Morning Star.',
  },
  {
    question: 'How long do exosomes stay in the body?',
    answer:
      'Exosomes typically remain active in the body for approximately 3 to 4 weeks after treatment. During this time, they continue to deliver regenerative signals to damaged tissues. The healing effects they initiate, however, can continue well beyond that window as the body\'s own repair mechanisms are activated.',
  },
  {
    question: 'What conditions can exosome therapy treat?',
    answer:
      'Exosome therapy is used for a variety of conditions including joint pain, soft tissue injuries, neuropathy, and chronic inflammatory conditions. It is particularly beneficial for patients who have not responded well to conventional treatments or who want to avoid surgery.',
  },
  {
    question: 'When can I expect to see results?',
    answer:
      'Most patients begin to notice improvement within 2 to 6 weeks following treatment, though results vary depending on the condition being treated and individual healing capacity. Some patients experience continued improvement for several months as the regenerative process progresses.',
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalWebPage',
      name: title,
      description: description,
      url: 'https://morningstarregmed.com/regenerative-medicine/regenerative-therapy/',
      isPartOf: {
        '@type': 'WebSite',
        name: 'Morning Star Neuropathy & Pain Treatment Center',
        url: 'https://morningstarregmed.com/',
      },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://morningstarregmed.com/' },
          { '@type': 'ListItem', position: 2, name: 'Regenerative Medicine', item: 'https://morningstarregmed.com/regenerative-medicine/' },
          { '@type': 'ListItem', position: 3, name: 'Regenerative Therapy' },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ question, answer }) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: { '@type': 'Answer', text: answer },
      })),
    },
  ],
});
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <TherapeuticProcedureSchema
      id="service-regenerative-therapy"
      name="Regenerative Therapy"
      description="Exosome-based regenerative therapy that reduces inflammation and supports cellular tissue repair for joints, nerves, and soft tissue."
      url="https://morningstarregmed.com/regenerative-medicine/regenerative-therapy/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      indication={["condition-neuropathy","condition-knee-pain","condition-back-pain","condition-joint-pain"]}
      bodyLocation={["joints","soft tissue","peripheral nerves"]}
      
      
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/regenerative-medicine/regenerative-therapy/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#service-regenerative-therapy"
      aspect="Treatment"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Regenerative Medicine","url":"https://morningstarregmed.com/regenerative-medicine/"},{"name":"Regenerative Therapy","url":"https://morningstarregmed.com/regenerative-medicine/regenerative-therapy/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-muted" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-primary">Home</a></li>
      <li>/</li>
      <li><a href="/regenerative-medicine/" class="hover:text-primary">Regenerative Medicine</a></li>
      <li>/</li>
      <li class="text-dark font-medium">Regenerative Therapy</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="bg-bg-warm py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-dark mb-6">
        Regenerative Therapy in St. Peters, MO
      </h1>
      <p class="text-xl text-body max-w-2xl">
        Harness your body's natural healing power with advanced exosome-based <b>regenerative therapy</b>. Reduce inflammation, support tissue repair, and recover without surgery.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 btn-primary inline-flex"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">What Is Exosome Therapy?</h2>
      <p class="text-body leading-relaxed mb-4">
        <b>Exosome therapy</b> is a regenerative treatment that uses exosomes (tiny extracellular vesicles packed with growth factors, proteins, and signaling molecules) to stimulate your body's own healing response. Unlike traditional approaches that mask symptoms, exosome therapy works at the cellular level to reduce inflammation and promote tissue repair.
      </p>
      <p class="text-body leading-relaxed mb-4">
        At <b>Morning Star Neuropathy &amp; Pain Treatment Center</b> in St. Peters, MO, exosome treatments are non-invasive and performed in-office. Our clinical team evaluates your condition to determine whether exosome therapy is the right fit for your recovery goals, often combining it with other modalities for the best possible outcome.
      </p>
      <p class="text-body leading-relaxed">
        This therapy is part of our broader <a href="/regenerative-medicine/" class="text-primary underline hover:text-primary-dark">regenerative medicine</a> program, which also includes <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-primary underline hover:text-primary-dark">PRP therapy</a> and <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary underline hover:text-primary-dark">hyaluronic acid injections</a>. Together, these treatments offer a range of non-surgical options for patients dealing with chronic pain and tissue damage.
      </p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-8">How Exosome Therapy Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">1. Clinical Assessment</div>
          <p class="text-body text-sm leading-relaxed">
            We review your medical history, current symptoms, and diagnostic imaging to determine the target area and appropriate treatment protocol.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">2. In-Office Treatment</div>
          <p class="text-body text-sm leading-relaxed">
            Exosomes are delivered directly to the affected area using guided injection techniques. The procedure is non-invasive with minimal discomfort and typically takes less than an hour.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <div class="text-primary font-bold text-lg mb-2">3. Recovery &amp; Healing</div>
          <p class="text-body text-sm leading-relaxed">
            Exosomes begin signaling your cells to repair damaged tissue immediately. Most patients resume normal activities quickly with follow-up visits to monitor progress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Conditions Treated -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Conditions Treated with Regenerative Therapy</h2>
      <p class="text-body leading-relaxed mb-6">
        Exosome therapy is effective for a wide range of conditions that involve tissue damage, inflammation, or degeneration. Patients in St. Peters and surrounding communities have found relief through this approach for:
      </p>
      <ul class="grid md:grid-cols-2 gap-3 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/neuropathy/" class="text-primary underline hover:text-primary-dark">Peripheral neuropathy</a> and nerve damage</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/knee-pain/" class="text-primary underline hover:text-primary-dark">Knee pain</a> from osteoarthritis or injury</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/back-pain/" class="text-primary underline hover:text-primary-dark">Back pain</a> caused by disc degeneration</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body"><a href="/conditions/joint-pain/" class="text-primary underline hover:text-primary-dark">Joint pain</a> in the shoulders, hips, and ankles</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Soft tissue injuries (tendons, ligaments, muscles)</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Chronic inflammatory conditions</span>
        </li>
      </ul>
      <p class="text-body leading-relaxed">
        Not sure if regenerative therapy is right for your situation? Our team can evaluate your condition during a consultation and recommend the most appropriate treatment path.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-8">Benefits of Exosome Therapy</h2>
      <ul class="grid md:grid-cols-2 gap-4">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Regenerates damaged tissue at the cellular level</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Reduces chronic inflammation</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Non-invasive, in-office procedure</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Minimal downtime and fast recovery</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Supports the body's natural healing mechanisms</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">&#10003;</span>
          <span class="text-body">Alternative to surgery and heavy medications</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Why Morning Star -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-dark mb-6">Why Choose Morning Star for Regenerative Therapy?</h2>
      <p class="text-body leading-relaxed mb-4">
        Morning Star Neuropathy &amp; Pain Treatment Center takes a patient-first approach to regenerative care. Every treatment plan starts with a thorough evaluation, because the right therapy depends on your specific condition, medical history, and goals. We do not apply a one-size-fits-all protocol.
      </p>
      <p class="text-body leading-relaxed mb-4">
        Our clinical team has extensive experience with exosome-based therapies and works alongside patients to track progress at every stage. Located at 4710 Mexico Rd Suite C in St. Peters, MO, our office is designed for comfort and efficiency, so you can receive treatment and get back to your day.
      </p>
      <p class="text-body leading-relaxed">
        If exosome therapy is not the best fit, we may recommend <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-primary underline hover:text-primary-dark">platelet-rich plasma (PRP) therapy</a> or <a href="/regenerative-medicine/hyaluronic-acid-injections/" class="text-primary underline hover:text-primary-dark">hyaluronic acid injections</a> instead. The goal is always to find the treatment that gives you the most meaningful relief.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-2xl p-6 border border-border">
            <dt class="font-semibold text-dark mb-2">{question}</dt>
            <dd class="text-body text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Discover What Exosome Therapy Can Do for You</h2>
      <p class="text-white/70 mb-8">
        Ready to explore a regenerative approach to healing? Contact Morning Star at <a href="tel:+16362440124" class="text-white underline hover:text-blue-100">(636) 244-0124</a> to find out if exosome therapy is right for your condition.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-heading font-semibold text-base px-8 py-4 rounded-full transition-all duration-200 shadow-lg"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white hover:text-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
