---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalConditionSchema from '@/components/schemas/MedicalConditionSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Back Pain Treatment in St. Peters, MO | Morning Star';
const description =
  'Find lasting back pain relief at Morning Star in St. Peters, MO. Expert diagnosis and non-invasive treatment for acute and chronic back conditions.';

const faqs = [
  {
    question: 'What are the most common causes of back pain?',
    answer:
      'The most common causes of back pain include poor posture, muscle strains from lifting heavy objects, herniated or bulging discs, and injuries from accidents or falls. Sedentary lifestyles and spending long hours hunching over phones or computers have also become leading contributors to back pain in recent years.',
  },
  {
    question: 'When is back pain serious enough to see a doctor?',
    answer:
      'You should see a doctor when back pain is recurring, lasts more than a few weeks, or begins to impact your quality of life. Seek immediate care if your pain is accompanied by numbness in your legs, difficulty walking, loss of bladder or bowel control, or if it follows a traumatic injury such as a fall or car accident.',
  },
  {
    question: 'Are there home remedies for back pain?',
    answer:
      'For minor back pain, rest combined with alternating heat and cold therapy can provide temporary relief. Over-the-counter anti-inflammatory medications, gentle stretching, and maintaining good posture also help. However, if your pain persists beyond a few days or worsens, professional evaluation is recommended to rule out structural or nerve-related causes.',
  },
  {
    question: 'Can back pain be caused by nerve problems?',
    answer:
      'Yes, back pain is frequently caused by nerve-related issues such as a pinched nerve, sciatica, or spinal stenosis. These conditions occur when spinal structures compress or irritate nearby nerves, producing pain that often radiates into the buttocks, legs, or feet. At Morning Star, our providers perform thorough evaluations to determine whether your pain is muscular, spinal, or nerve-related.',
  },
  {
    question: 'What treatment options does Morning Star offer for back pain?',
    answer:
      'Morning Star offers a range of non-invasive treatments for back pain, including regenerative therapy to promote tissue healing, chronic pain management programs, and platelet-rich plasma (PRP) therapy to accelerate recovery. Our team creates personalized treatment plans based on the source and severity of your pain.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalConditionSchema
      id="condition-back-pain"
      name="Back Pain"
      description="Chronic back pain affects millions of adults. Learn about causes, symptoms, and non-surgical back pain treatment options in St. Peters, MO."
      url="https://morningstarregmed.com/conditions/back-pain/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      possibleTreatments={["service-regenerative-therapy","service-chronic-pain-management","service-platelet-rich-plasma-therapy"]}
      causes={["Herniated disc","Degenerative disc disease","Muscle strain","Spinal stenosis","Osteoarthritis"]}
      signOrSymptom={["Lower back pain","Radiating leg pain","Muscle spasm","Limited mobility","Pain when sitting"]}
      associatedAnatomy="Lumbar spine"
      riskFactor={["Sedentary lifestyle","Poor posture","Age","Overweight","Heavy lifting"]}
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/conditions/back-pain/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#condition-back-pain"
      aspect="Symptom"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Conditions","url":"https://morningstarregmed.com/conditions/"},{"name":"Back Pain","url":"https://morningstarregmed.com/conditions/back-pain/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Hero -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-white mb-5">Back Pain Treatment in St.&nbsp;Peters, MO</h1>
      <p class="text-white/80 text-lg leading-relaxed">
        Back pain is one of the most common reasons people seek medical care, and it can range from a
        mild inconvenience to a condition that disrupts every part of your day. At Morning Star
        Neuropathy &amp; Pain Treatment Center in St.&nbsp;Peters, MO, we provide expert diagnosis and
        personalized, non-invasive treatment to help you find lasting relief.
      </p>
      <a
        href="/schedule-appointment/"
        class="mt-8 btn-primary inline-flex"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Understanding Back Pain -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Understanding Back Pain</h2>
      <p class="text-body mb-4 leading-relaxed">
        <strong>Back pain</strong> affects roughly 80 percent of adults at some point in their lives.
        While minor cases often resolve on their own with rest and self-care, chronic or severe back
        pain requires professional attention to prevent long-term damage and restore normal function.
      </p>
      <p class="text-body mb-4 leading-relaxed">
        Poor posture and injuries remain the primary drivers. In today's digital world, hunching over
        phones and computers for hours each day has dramatically increased the number of people
        experiencing back problems, even among younger adults. When you factor in the physical toll of
        repetitive motions, heavy lifting, or sedentary lifestyles, the scope of the problem becomes
        clear.
      </p>
      <p class="text-body leading-relaxed">
        Treatment ranges from simple rest combined with heat and cold therapy for minor cases to
        comprehensive pain management programs for chronic conditions. The key is working with medical
        providers who can determine whether your pain is muscular, spinal, or nerve-related, because
        the source of your pain dictates the most effective treatment approach.
      </p>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Common Causes of Back Pain</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Disc Issues</h3>
          <p class="text-body text-sm leading-relaxed">
            <strong>Herniated discs</strong>, bulging discs, and degenerative disc disease can press
            on spinal nerves, causing localized pain or radiating symptoms that travel through the
            back and down into the legs.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Muscle Strain</h3>
          <p class="text-body text-sm leading-relaxed">
            Lifting heavy objects incorrectly, sudden awkward movements, sports injuries, and auto
            accidents can strain muscles or damage the ligaments and tendons that support the spine.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Spinal Stenosis</h3>
          <p class="text-body text-sm leading-relaxed">
            A narrowing of the spinal canal that puts pressure on the spinal cord and nerves. This
            condition is most common in adults over 50 and causes pain, numbness, and weakness in the
            back and legs.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Degenerative Conditions</h3>
          <p class="text-body text-sm leading-relaxed">
            Osteoarthritis and other age-related changes in the spine gradually break down cartilage,
            discs, and joint surfaces, leading to chronic stiffness and pain.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border md:col-span-2">
          <h3 class="font-semibold text-dark mb-2">Postural Habits</h3>
          <p class="text-body text-sm leading-relaxed">
            Slouching, hunching over screens, and poor workplace ergonomics place excessive stress on
            the spine, muscles, and ligaments. Over months and years, these habits create structural
            imbalances that produce chronic pain, even in younger adults.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Symptoms to Watch For</h2>
      <p class="text-body mb-6 leading-relaxed">
        <strong>Back pain symptoms</strong> vary widely depending on the cause and location of the
        problem. Common signs that warrant attention include:
      </p>
      <ul class="space-y-3 text-body">
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Dull, aching pain in the lower, middle, or upper back</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Sharp or shooting pain that radiates down the legs</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Stiffness and reduced range of motion</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Muscle spasms or persistent tightness</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain that worsens with sitting, standing, or bending</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Numbness or tingling in the legs or feet</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain that disrupts sleep or makes it difficult to find a comfortable position</li>
      </ul>
    </div>
  </section>

  <!-- Treatment Options at Morning Star -->
  <section class="relative bg-dark py-20 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">Treatment Options at Morning Star</h2>
      <p class="text-body mb-6 leading-relaxed">
        At Morning Star in St.&nbsp;Peters, we take a comprehensive approach to <strong>back pain
        treatment</strong>. Our team begins with a thorough evaluation to identify the exact source of
        your pain, then develops a personalized plan that may include one or more of the following
        therapies.
      </p>

      <div class="space-y-4">
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Regenerative Therapy</h3>
          <p class="text-body text-sm leading-relaxed">
            Our <a href="/regenerative-medicine/regenerative-therapy/" class="text-primary underline hover:text-primary-dark">regenerative therapy</a>
            program uses advanced treatments that promote natural healing of damaged tissues and
            reduce inflammation in the spine and surrounding structures. This approach helps the body
            repair disc, muscle, and ligament damage without surgery.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Chronic Pain Management</h3>
          <p class="text-body text-sm leading-relaxed">
            Our <a href="/pain-management/chronic-pain-management/" class="text-primary underline hover:text-primary-dark">chronic pain management</a>
            program provides targeted interventions to reduce pain levels and improve function. For
            patients dealing with long-standing back problems, this structured approach addresses both
            the physical and functional aspects of chronic pain.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark mb-2">Platelet-Rich Plasma (PRP) Therapy</h3>
          <p class="text-body text-sm leading-relaxed">
            <a href="/regenerative-medicine/platelet-rich-plasma-therapy/" class="text-primary underline hover:text-primary-dark">PRP therapy</a>
            concentrates growth factors from your own blood and delivers them directly to the injured
            area, accelerating tissue repair and reducing inflammation. This treatment is effective
            for disc injuries, muscle tears, and ligament damage.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-6">When to Seek Professional Help</h2>
      <p class="text-body mb-4 leading-relaxed">
        While minor back pain often improves with rest, you should seek professional care when pain is
        recurring, intensifying, or beginning to impact your quality of life. Specific warning signs
        include:
      </p>
      <ul class="space-y-2 text-body mb-6">
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain lasting more than two weeks without improvement</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Numbness, tingling, or weakness in your legs</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain following a traumatic injury or accident</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Difficulty sleeping due to back pain</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Pain that prevents you from working or performing daily tasks</li>
        <li class="flex items-start gap-2"><span class="text-primary">&#8226;</span> Loss of bladder or bowel control (seek immediate care)</li>
      </ul>
      <p class="text-body leading-relaxed">
        Do not wait for back pain to resolve on its own if it has been affecting you for more than two
        weeks. Call Morning Star at
        <a href="tel:+16362440124" class="text-primary underline hover:text-primary-dark">(636) 244-0124</a>
        to schedule your evaluation.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-dark mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-2xl p-6 border border-border">
            <dt class="font-semibold text-dark mb-2">{question}</dt>
            <dd class="text-body text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-dark text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Stop Living With Back Pain</h2>
      <p class="text-white/70 mb-8">
        Contact Morning Star Neuropathy &amp; Pain Treatment Center in St.&nbsp;Peters, MO today to
        schedule your evaluation and start your journey toward a pain-free life.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="px-8 py-3 bg-white text-dark font-semibold rounded-xl hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact-us/"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-xl hover:bg-white hover:text-dark transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
