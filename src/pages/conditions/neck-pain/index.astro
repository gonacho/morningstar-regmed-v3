---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MedicalConditionSchema from '@/components/schemas/MedicalConditionSchema.astro';
import MedicalWebPageSchema from '@/components/schemas/MedicalWebPageSchema.astro';
import BreadcrumbSchema from '@/components/schemas/BreadcrumbSchema.astro';
import FAQPageSchema from '@/components/schemas/FAQPageSchema.astro';

const title = 'Neck Pain Treatment in St. Peters, MO | Morning Star';
const description =
  'Neck pain treatment at Morning Star in St. Peters, MO. Address stress-related and postural neck pain with personalized, non-invasive care plans.';

const faqs = [
  {
    question: 'What are the most common causes of neck pain?',
    answer:
      'The most common causes include poor posture (especially from prolonged screen time), muscle strain from stress or tension, cervical disc problems, whiplash from auto accidents, and age-related degenerative changes in the spine. Many patients experience neck pain from a combination of these factors rather than a single cause.',
  },
  {
    question: 'Will neck pain go away on its own?',
    answer:
      'Mild neck pain caused by temporary muscle strain or sleeping in an awkward position often resolves within a few days to a week. However, neck pain that persists for more than two weeks, radiates into the arms or hands, or is accompanied by numbness and tingling typically requires professional evaluation. Ignoring chronic neck pain can allow the underlying condition to worsen over time.',
  },
  {
    question: 'When is neck pain considered serious?',
    answer:
      'Neck pain is considered serious when it follows a traumatic injury, is accompanied by numbness or weakness in the arms or hands, causes headaches that do not respond to over-the-counter medication, or disrupts sleep and daily activities for more than two weeks. Pain that radiates down the arm (radiculopathy) may indicate nerve compression and should be evaluated promptly.',
  },
  {
    question: 'What neck pain treatment options does Morning Star offer?',
    answer:
      'Morning Star offers non-invasive treatment options including neuromodulation technique and chronic pain management programs. Our team evaluates the specific cause of your neck pain and builds a personalized plan that may combine multiple therapies to reduce pain, restore mobility, and address the root cause rather than masking symptoms.',
  },
  {
    question: 'How can I prevent neck pain from coming back?',
    answer:
      'Prevention starts with maintaining proper posture, especially at a desk or while using a phone. Regular stretching, strengthening exercises for the neck and upper back, ergonomic workspace adjustments, and stress management all play important roles. Patients who complete a treatment plan at Morning Star receive guidance on exercises and lifestyle changes to reduce the risk of recurrence.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <MedicalConditionSchema
      id="condition-neck-pain"
      name="Neck Pain"
      description="Neck pain from muscle strain, disc issues, or nerve compression can disrupt daily life. Explore non-surgical neck pain treatment in St. Peters, MO."
      url="https://morningstarregmed.com/conditions/neck-pain/"
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      possibleTreatments={["service-neuromodulation-technique","service-chronic-pain-management"]}
      causes={["Muscle strain","Cervical disc herniation","Osteoarthritis","Poor posture","Whiplash injury"]}
      signOrSymptom={["Neck stiffness","Radiating arm pain","Headache","Shoulder pain","Numbness in arms"]}
      associatedAnatomy="Cervical spine"
      riskFactor={["Desk work","Poor posture","Prior neck injury","Age"]}
    />
    <MedicalWebPageSchema
      url="https://morningstarregmed.com/conditions/neck-pain/"
      name={title}
      description={description}
      publishDate="2024-01-01"
      lastEdited="2025-05-13"
      mainEntityId="https://morningstarregmed.com/#condition-neck-pain"
      aspect="Symptom"
    />
    <BreadcrumbSchema items={[{"name":"Home","url":"https://morningstarregmed.com"},{"name":"Conditions","url":"https://morningstarregmed.com/conditions/"},{"name":"Neck Pain","url":"https://morningstarregmed.com/conditions/neck-pain/"}]} />
    <FAQPageSchema faqs={faqs} />
  </Fragment>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 pt-6 text-sm text-gray-500" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5">
      <li><a href="/" class="hover:text-brand-blue">Home</a></li>
      <li>/</li>
      <li><a href="/conditions/" class="hover:text-brand-blue">Conditions</a></li>
      <li>/</li>
      <li class="text-brand-navy font-medium">Neck Pain</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Neck Pain Treatment in St. Peters, MO
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        Personalized, non-invasive treatment plans to relieve <strong>neck pain</strong> at its source, restore your range of motion, and help you get back to the activities that matter most.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a
          href="/schedule-appointment/"
          class="inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
        >
          Schedule a Consultation
        </a>
        <a
          href="tel:6362440124"
          class="inline-block px-8 py-3 border-2 border-brand-blue text-brand-blue font-semibold rounded-lg hover:bg-brand-blue hover:text-white transition-colors"
        >
          Call (636) 244-0124
        </a>
      </div>
    </div>
  </section>

  <!-- Understanding Neck Pain -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Understanding Neck Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Your cervical spine supports the full weight of your head (roughly 10 to 12 pounds) while allowing a wide range of motion. That combination of flexibility and load-bearing responsibility makes the neck especially vulnerable to pain, stiffness, and injury. <strong>Neck pain</strong> can develop gradually from repetitive strain or appear suddenly after an accident, and it affects people of all ages.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        For some patients, the discomfort stays localized to the neck and upper shoulders. For others, it radiates into the arms, causes headaches, or produces numbness and tingling in the hands. The pattern of symptoms often points to the underlying cause, which is why a thorough evaluation matters before starting any treatment.
      </p>
      <p class="text-gray-600 leading-relaxed">
        At Morning Star Neuropathy &amp; Pain Treatment Center in St. Peters, MO, we identify the root cause of your neck pain and develop a care plan that targets it directly. Our goal is not just to reduce your symptoms today, but to address the condition driving them so you experience lasting relief.
      </p>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">Common Causes of Neck Pain</h2>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Poor Posture</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Hours spent hunched over a computer or looking down at a phone place excessive strain on the muscles and ligaments of the cervical spine. Over time, this forward-head posture changes the natural curve of the neck and leads to chronic muscle fatigue, stiffness, and pain.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Stress &amp; Muscle Tension</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Emotional stress triggers involuntary tightening of the muscles in the neck and upper back. When this tension becomes habitual, it restricts blood flow to the area and creates persistent pain that may also contribute to tension headaches.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Cervical Disc Issues</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        Herniated or bulging discs in the cervical spine can press on nearby nerves, producing sharp pain, radiating arm symptoms, and reduced range of motion. Disc problems may develop from a single injury or from gradual wear on the spine.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Whiplash</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        A sudden, forceful back-and-forth movement of the neck (most common in car accidents) can damage muscles, ligaments, and discs. Whiplash symptoms sometimes take days to appear, making early evaluation important even after seemingly minor collisions.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Degenerative Conditions</h3>
      <p class="text-gray-600 leading-relaxed">
        <strong>Cervical spondylosis</strong>, osteoarthritis, and spinal stenosis are age-related conditions that narrow the spaces within the spine and put pressure on nerves. These conditions tend to develop slowly, with symptoms worsening over months or years if left untreated.
      </p>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Symptoms of Neck Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-6">
        Neck pain presents differently depending on the underlying cause. Common symptoms include:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Persistent aching or stiffness in the neck and upper shoulders</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Sharp pain that worsens with movement or turning the head</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Radiating pain into the arms, hands, or upper back</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Numbness or tingling in the fingers</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Headaches originating at the base of the skull</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Difficulty maintaining a comfortable sleeping position</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Muscle spasms in the neck or upper trapezius area</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Reduced range of motion when looking left, right, or overhead</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        If any of these symptoms persist for more than two weeks, or if you experience sudden onset of numbness and weakness, professional evaluation is strongly recommended.
      </p>
    </div>
  </section>

  <!-- Treatment at Morning Star -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Neck Pain Treatment at Morning Star</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Our team begins with a thorough evaluation of your symptoms, medical history, and diagnostic findings. From there, we build a treatment plan tailored to your specific condition. Morning Star focuses on non-invasive therapies that address the source of pain rather than covering it up.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Neuromodulation Technique</h3>
      <p class="text-gray-600 leading-relaxed mb-6">
        <a href="/pain-management/neuromodulation-technique/" class="text-brand-blue hover:underline">Neuromodulation technique</a> uses controlled electrical stimulation to interrupt pain signals traveling from the cervical spine to the brain. For patients with nerve-related neck pain, this therapy can reduce chronic discomfort and improve daily function without surgery or ongoing medication.
      </p>

      <h3 class="text-xl font-semibold text-brand-navy mb-3">Chronic Pain Management</h3>
      <p class="text-gray-600 leading-relaxed">
        Our <a href="/pain-management/chronic-pain-management/" class="text-brand-blue hover:underline">chronic pain management</a> program combines multiple therapies into one coordinated plan. For neck pain patients, this may include neuromodulation, targeted exercises, ergonomic recommendations, and lifestyle adjustments designed to reduce strain on the cervical spine and prevent recurrence.
      </p>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">When to Seek Help for Neck Pain</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Not all neck pain requires medical attention. Mild stiffness from a poor sleeping position or a long day at the desk often resolves with rest, gentle stretching, and over-the-counter remedies. However, you should schedule a professional evaluation if your neck pain:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Lasts more than two weeks without improvement</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Radiates into your arms or hands</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Developed after an accident or injury</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Includes numbness, tingling, or weakness</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Disrupts your sleep or daily activities</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        Early intervention gives treatment the best chance of success. The team at Morning Star in St. Peters is here to evaluate your condition and explain your options clearly, so you can make an informed decision about your care.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Address Your Neck Pain?</h2>
      <p class="text-blue-200 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> or schedule online. Our St. Peters team will evaluate your condition and walk you through every treatment option available to you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment/"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="tel:6362440124"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Call (636) 244-0124
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
