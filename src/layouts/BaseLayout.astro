---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Serialised JSON-LD object(s) for structured data. Pass a string or leave
   *  undefined; the layout will inject it inside <script type="application/ld+json">. */
  jsonLd?: string;
}

const {
  title,
  description = 'Morning Star Neuropathy & Pain Treatment Center in St. Peters, MO — advanced neuropathy care, regenerative therapy, and pain management.',
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://morningstarregmed.com').href;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Morning Star Neuropathy & Pain Treatment Center" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <!-- JSON-LD slot: child pages may inject additional structured data here -->
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-full bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    function initAnimations() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // ── Hero section entrance ──────────────────────────────────────────────
      const heroSection = document.querySelector('main section:first-child');
      if (heroSection) {
        const heroH1 = heroSection.querySelector('h1');
        const heroP = heroSection.querySelector('p');
        const heroCta = heroSection.querySelector('a');

        if (heroH1) {
          gsap.from(heroH1, {
            opacity: 0,
            y: 24,
            duration: 0.7,
            ease: 'power3.out',
          });
        }
        if (heroP) {
          gsap.from(heroP, {
            opacity: 0,
            y: 16,
            duration: 0.6,
            delay: 0.2,
            ease: 'power3.out',
          });
        }
        if (heroCta) {
          gsap.from(heroCta, {
            opacity: 0,
            y: 12,
            duration: 0.5,
            delay: 0.35,
            ease: 'power3.out',
          });
        }
      }

      // ── Section reveal on scroll ───────────────────────────────────────────
      const sections = document.querySelectorAll('main section:not(:first-child)');
      sections.forEach((section) => {
        const heading = section.querySelector('h2');
        if (heading) {
          gsap.from(heading, {
            opacity: 0,
            y: 20,
            duration: 0.6,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: heading,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          });
        }

        const paras = section.querySelectorAll('p');
        paras.forEach((p, i) => {
          gsap.from(p, {
            opacity: 0,
            y: 16,
            duration: 0.5,
            delay: i * 0.08,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: p,
              start: 'top 90%',
              toggleActions: 'play none none none',
            },
          });
        });
      });

      // ── Card grids: stagger entrance ──────────────────────────────────────
      document.querySelectorAll('.grid').forEach((grid) => {
        const cards = grid.querySelectorAll('a, > div');
        if (cards.length > 1) {
          gsap.from(cards, {
            opacity: 0,
            y: 20,
            duration: 0.5,
            stagger: 0.08,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: grid,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          });
        }
      });

      // ── Header: subtle elevation on scroll ────────────────────────────────
      const header = document.getElementById('site-header');
      if (header) {
        ScrollTrigger.create({
          start: 'top -60',
          onEnter: () => header.classList.add('shadow-brand'),
          onLeaveBack: () => header.classList.remove('shadow-brand'),
        });
      }
    }

    // Run on initial load and after Astro view transitions
    document.addEventListener('astro:page-load', initAnimations);

    // Clean up ScrollTriggers between page navigations
    document.addEventListener('astro:after-swap', () => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
    });
  </script>
</html>
