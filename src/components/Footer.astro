---
const year = new Date().getFullYear();
---

<footer class="bg-brand-navy text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="font-bold text-lg mb-3">Morningstar RegMed</h3>
        <p class="text-blue-200 text-sm leading-relaxed">
          Regulatory and medical affairs consulting for the life sciences industry.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wide mb-3 text-blue-300">Navigation</h4>
        <ul class="space-y-2">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About' },
            { href: '/services', label: 'Services' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-blue-200 hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wide mb-3 text-blue-300">Contact</h4>
        <p class="text-blue-200 text-sm">
          <a href="/contact" class="hover:text-white transition-colors">Get in touch →</a>
        </p>
      </div>
    </div>

    <div class="border-t border-blue-800 mt-10 pt-6 text-center text-blue-300 text-xs">
      &copy; {year} Morningstar RegMed. All rights reserved.
    </div>
  </div>
</footer>
