---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Neuropathy And Pain Treatment in Missouri';
const description =
  'Learn about neuropathy causes, symptoms, and treatment options at Morning Star in St. Peters, MO. Expert care for nerve damage and neuropathic pain.';

const faqs = [
  {
    question: 'What is the main cause of neuropathy?',
    answer:
      'Diabetes is the most common cause of peripheral neuropathy. High blood sugar levels over time damage the nerves, particularly in the hands and feet. However, neuropathy can also result from infections, traumatic injuries, autoimmune disorders, vitamin deficiencies, and exposure to toxins.',
  },
  {
    question: 'Can neuropathy be cured?',
    answer:
      'In most cases, neuropathy cannot be fully cured, but it can be effectively managed. Treatment focuses on addressing the underlying cause, relieving symptoms, and preventing further nerve damage. Many patients experience significant improvement in their quality of life with the right treatment plan.',
  },
  {
    question: 'What makes neuropathy worse?',
    answer:
      'Several factors can worsen neuropathy symptoms, including poor blood sugar control, smoking, excessive alcohol consumption, exposure to toxins, and certain infections. Maintaining a healthy lifestyle and managing underlying conditions is essential to slowing the progression of nerve damage.',
  },
  {
    question: 'Can sitting too long cause nerve damage?',
    answer:
      'Yes, prolonged sitting can contribute to nerve damage through compression. Sitting for extended periods puts pressure on nerves, particularly in the legs and lower back, which can lead to numbness, tingling, and pain. Taking regular breaks to stand and move is important for nerve health.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
});
---

<BaseLayout title={title} description={description} jsonLd={faqSchema}>
  <!-- Hero -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Understanding Neuropathy</h1>
      <p class="text-xl text-gray-600">
        Neuropathy affects millions of Americans, causing tingling, numbness, weakness, and pain that
        can disrupt every aspect of daily life. At Morning Star in St.&nbsp;Peters, MO, we help
        patients understand their condition and find a path toward lasting relief.
      </p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Condition Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">What Is Neuropathy?</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Neuropathy, also called peripheral neuropathy, is a condition that occurs when the peripheral
        nerves — the vast network that transmits signals between the brain, spinal cord, and the rest
        of the body — become damaged. This damage disrupts normal nerve signaling, leading to
        symptoms such as tingling, numbness, burning sensations, weakness, and chronic pain,
        typically starting in the hands and feet.
      </p>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Unlike our treatment-focused <a href="/neuropathy-treatment" class="text-brand-blue underline hover:text-blue-700">neuropathy treatment page</a>,
        this page is designed to help you understand the condition itself — what causes it, how it
        progresses, and why early intervention matters.
      </p>
    </div>
  </section>

  <!-- Types of Neuropathy -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Types of Neuropathy</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Sensory Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Affects the nerves that carry sensations such as pain, temperature, and touch. Symptoms
            include tingling, numbness, and burning pain in the extremities.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Motor Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Damages the nerves that control muscle movement, leading to weakness, muscle wasting, and
            difficulty with coordination and balance.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Autonomic Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Affects involuntary body functions such as heart rate, blood pressure, digestion, and
            bladder control. This type can cause dizziness, digestive issues, and abnormal sweating.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Combination Neuropathy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Many patients experience a mix of sensory, motor, and autonomic nerve damage
            simultaneously, which is why a comprehensive evaluation is essential for effective
            treatment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Common Causes of Neuropathy</h2>
      <ul class="space-y-3 text-gray-600">
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Diabetes</strong> — the leading cause, responsible for roughly half of all neuropathy cases</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Infections</strong> — Lyme disease, shingles, hepatitis, and HIV can damage nerves</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Autoimmune disorders</strong> — lupus, rheumatoid arthritis, and Guillain-Barr&eacute; syndrome</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Toxin exposure</strong> — heavy metals, industrial chemicals, and certain medications</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Vitamin deficiencies</strong> — particularly B vitamins essential for nerve health</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-brand-blue font-bold mt-1">&#10003;</span>
          <span><strong>Traumatic injuries</strong> — accidents, falls, or repetitive stress injuries</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Symptoms of Neuropathy</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Neuropathy symptoms vary depending on which nerves are affected, but commonly include:
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Tingling or "pins and needles" in hands and feet</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Numbness or reduced ability to feel pain or temperature</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Sharp, burning, or stabbing pain</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Muscle weakness and loss of coordination</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Sensitivity to touch, even light pressure</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Balance problems and difficulty walking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">When to Seek Help</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Early treatment is critical for neuropathy. The longer nerve damage goes unaddressed, the
        harder it becomes to manage symptoms and prevent further deterioration. You should seek
        professional care if you experience:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Persistent tingling or numbness that does not resolve</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Pain that interferes with sleep, work, or daily activities</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Weakness in your hands or feet that affects grip or balance</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Symptoms that are gradually worsening over time</li>
      </ul>
      <p class="text-gray-600 leading-relaxed">
        At Morning Star, we provide thorough evaluations to identify the underlying cause of your
        neuropathy and develop a personalized care plan tailored to your needs.
      </p>
    </div>
  </section>

  <!-- Treatment Options at Morning Star -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Treatment Options at Morning Star</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Our team in St.&nbsp;Peters, MO specializes in advanced, non-invasive approaches to
        neuropathy care. We focus on reducing pain, restoring function, and slowing disease
        progression through:
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Regenerative Therapy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Advanced regenerative treatments that support nerve repair and reduce inflammation at the
            cellular level.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Pain Management</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Targeted pain management strategies to provide relief from neuropathic pain and improve
            your comfort.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Neuromodulation</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Specialized techniques that modify nerve activity to reduce pain signals and restore
            normal nerve function.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Lifestyle Guidance</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Personalized recommendations for diet, exercise, and daily habits that support nerve
            health and overall wellness.
          </p>
        </div>
      </div>
      <p class="text-gray-600 mt-6 leading-relaxed">
        Learn more about our specific treatment protocols on our
        <a href="/neuropathy-treatment" class="text-brand-blue underline hover:text-blue-700">neuropathy treatment page</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Take the First Step Toward Relief</h2>
      <p class="text-blue-200 mb-8">
        Do not let neuropathy control your life. Contact Morning Star in St.&nbsp;Peters, MO today
        to schedule your consultation and begin your journey to better nerve health.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
