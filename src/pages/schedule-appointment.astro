---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Schedule an Appointment"
  description="Schedule a consultation with Morningstar RegMed. Contact us to discuss your pain management or regenerative medicine needs."
>
  <!-- Page header -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Schedule an Appointment</h1>
      <p class="text-xl text-gray-600">
        Take the first step toward lasting relief. Reach out to schedule your consultation.
      </p>
    </div>
  </section>

  <!-- Scheduling options -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Phone / direct CTA -->
      <div class="bg-brand-light rounded-xl p-8 flex flex-col gap-4">
        <h2 class="text-2xl font-bold text-brand-navy">Call Us</h2>
        <p class="text-gray-600">
          Speak directly with our scheduling team to find the appointment time that works for you.
        </p>
        <p class="text-gray-500 text-sm">Placeholder — phone number coming in Phase 2.</p>
        <a
          href="tel:+1-000-000-0000"
          class="mt-auto px-6 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors text-center"
        >
          Call Now
        </a>
      </div>

      <!-- Online form placeholder -->
      <div class="border border-gray-200 rounded-xl p-8 flex flex-col gap-4">
        <h2 class="text-2xl font-bold text-brand-navy">Request Online</h2>
        <p class="text-gray-600">
          Fill out the form below and our team will contact you within one business day.
        </p>

        <!-- Form placeholder — integrate scheduling widget in Phase 2 -->
        <form class="space-y-4 mt-2" aria-label="Appointment request form">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="jane@example.com"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue"
              placeholder="(555) 000-0000"
            />
          </div>
          <div>
            <label for="reason" class="block text-sm font-medium text-gray-700 mb-1">
              Reason for Visit
            </label>
            <textarea
              id="reason"
              name="reason"
              rows={3}
              class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue resize-none"
              placeholder="Briefly describe your condition or treatment interest…"
            />
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3 bg-brand-navy text-white font-semibold rounded-lg hover:bg-blue-900 transition-colors"
          >
            Request Appointment
          </button>
          <p class="text-xs text-gray-400 text-center">
            Form submission placeholder — backend integration coming in Phase 2.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
