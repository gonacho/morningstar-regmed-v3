---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Knee Pain Treatment in St. Peters, MO';
const description =
  'Knee pain treatment at Morning Star in St. Peters, MO. Expert care for meniscus tears, arthritis, and chronic knee conditions without surgery.';

const faqs = [
  {
    question: 'What are the most common causes of knee pain?',
    answer:
      'The most common causes of knee pain include meniscus tears, osteoarthritis, ligament injuries (such as ACL tears), tendinitis, bursitis, and overuse from repetitive activities. Excess body weight also places additional stress on the knee joints, accelerating wear and tear.',
  },
  {
    question: 'When should I see a doctor for knee pain?',
    answer:
      'You should see a doctor if your knee pain lasts beyond one week, as this usually indicates a larger underlying issue. Seek immediate care if you heard a popping sound at the time of injury, cannot bear weight on the knee, experience significant swelling, or notice the knee locking or giving way.',
  },
  {
    question: 'What treatment options are available for knee pain?',
    answer:
      'Morning Star offers multiple non-surgical treatment options for knee pain, including hyaluronic acid injections to restore joint lubrication, platelet-rich plasma therapy to promote tissue repair, orthotic support such as knee braces, regenerative therapy, and comprehensive pain management programs.',
  },
  {
    question: 'Can knee pain be prevented?',
    answer:
      'Many knee problems can be prevented by maintaining a healthy weight, strengthening the muscles that support the knee, using proper form during exercise, wearing appropriate footwear, and warming up before physical activity. Low-impact exercises like swimming and cycling are excellent for knee health.',
  },
  {
    question: 'What age group is most affected by knee pain?',
    answer:
      'Knee pain reaches its peak prevalence between ages 55 and 64, primarily due to osteoarthritis and accumulated wear. However, knee pain can occur at any age — younger adults frequently experience knee injuries from sports, while middle-aged adults may develop pain from overuse or early arthritis.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
});
---

<BaseLayout title={title} description={description} jsonLd={faqSchema}>
  <!-- Hero -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Knee Pain Treatment in St.&nbsp;Peters, MO</h1>
      <p class="text-xl text-gray-600">
        Knee pain can limit your mobility and keep you from the activities you love. At Morning Star
        in St.&nbsp;Peters, MO, we provide expert diagnosis and non-surgical treatment options to
        help you get back on your feet — without the need for invasive procedures.
      </p>
      <a
        href="/schedule-appointment"
        class="mt-8 inline-block px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        Schedule a Consultation
      </a>
    </div>
  </section>

  <!-- Condition Overview -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Understanding Knee Pain</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Knee pain is one of the most common musculoskeletal complaints, with peak prevalence
        occurring between ages 55 and 64. However, knee problems can develop at any age due to
        injuries, overuse, or underlying conditions.
      </p>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Meniscus tears are among the most frequent knee injuries. The meniscus is a C-shaped piece
        of cartilage that acts as a cushion between your shinbone and thighbone. When torn, you may
        experience a popping sensation, swelling, stiffness, and pain — especially when twisting or
        rotating the knee. Without treatment, a torn meniscus can lead to chronic knee problems and
        accelerated joint deterioration.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Orthotics such as knee braces can provide support and stability, but they are most effective
        as part of a comprehensive treatment plan. Pain that lasts beyond one week typically
        indicates a larger issue that requires professional evaluation and targeted treatment.
      </p>
    </div>
  </section>

  <!-- Common Causes -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Common Causes of Knee Pain</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Meniscus Tears</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Tears in the cartilage cushion of the knee, often caused by sudden twisting or rotating
            movements. Symptoms include popping sensations, swelling, and pain during movement.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Osteoarthritis</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Progressive cartilage deterioration in the knee joint that causes bones to grind against
            each other, resulting in pain, stiffness, and reduced mobility.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Ligament Injuries</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            ACL, MCL, and other ligament tears or sprains commonly occur during sports or sudden
            changes in direction, causing instability and significant pain.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Overuse and Tendinitis</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Repetitive stress from running, jumping, or climbing stairs can inflame the tendons
            around the knee, leading to chronic pain and discomfort.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Symptoms to Watch For</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Popping or clicking sounds during movement</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Swelling and stiffness in the knee</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Pain when twisting, rotating, or bending the knee</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Difficulty straightening the knee fully</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">The knee locking or giving way unexpectedly</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <p class="text-gray-600 text-sm">Pain that worsens with stairs, squatting, or kneeling</p>
        </div>
      </div>
    </div>
  </section>

  <!-- When to Seek Help -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">When to Seek Professional Help</h2>
      <p class="text-gray-600 mb-4 leading-relaxed">
        Knee pain that lasts beyond one week usually indicates a larger issue that needs professional
        attention. You should schedule an evaluation if:
      </p>
      <ul class="space-y-2 text-gray-600 mb-6">
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> Pain persists for more than one week despite rest</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> You cannot bear weight on the affected knee</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> The knee is visibly swollen, red, or warm to the touch</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> You heard a popping sound at the time of injury</li>
        <li class="flex items-start gap-2"><span class="text-brand-blue">&#8226;</span> The knee feels unstable or locks during movement</li>
      </ul>
    </div>
  </section>

  <!-- Treatment Options -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Treatment Options at Morning Star</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Our non-surgical approach to knee pain focuses on reducing inflammation, promoting healing,
        and restoring function. Your personalized treatment plan may include:
      </p>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Hyaluronic Acid Injections</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Restore the natural lubrication in your knee joint, reducing bone-on-bone friction and
            providing significant pain relief for osteoarthritis patients.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Platelet-Rich Plasma (PRP) Therapy</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Growth factors concentrated from your own blood are injected into the knee to accelerate
            tissue repair and reduce inflammation.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Orthotic Support</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Custom knee braces and orthotic devices provide stability and support during the healing
            process and daily activities.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Pain Management</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Comprehensive pain management strategies to control discomfort while addressing the
            underlying cause of your knee pain.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-6">
        {faqs.map(({ question, answer }) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <dt class="font-semibold text-brand-navy mb-2">{question}</dt>
            <dd class="text-gray-600 text-sm leading-relaxed">{answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Get Back on Your Feet</h2>
      <p class="text-blue-200 mb-8">
        Do not let knee pain keep you sidelined. Contact Morning Star in St.&nbsp;Peters, MO today
        to schedule your evaluation and start your recovery.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule-appointment"
          class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors"
        >
          Schedule Appointment
        </a>
        <a
          href="/contact"
          class="px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-brand-navy transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
