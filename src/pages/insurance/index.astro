---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Insurance & Payment Options | Morning Star in St. Peters, MO';
const description =
  'Morning Star in St. Peters, MO accepts major medical insurance. Learn about payment options including CareCredit financing.';
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-brand-light py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">
        Insurance &amp; Payment Options
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl">
        We believe cost should not stand between you and effective pain treatment. Morning Star accepts major medical insurance plans and offers flexible payment options to make care accessible.
      </p>
    </div>
  </section>

  <!-- Insurance -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Insurance Coverage</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Morning Star accepts most major medical insurance plans. Coverage varies by plan, service, and diagnosis. We recommend calling your insurance provider before your appointment to confirm benefits for the specific treatment being discussed.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        Our front desk team is available to help you verify coverage and answer questions about your benefits. Call <a href="tel:6362440124" class="text-brand-blue hover:underline">(636) 244-0124</a> and we will do our best to clarify what your plan covers before your first visit.
      </p>
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-6">
        <p class="text-gray-700 text-sm">
          <strong>Note:</strong> Insurance coverage for regenerative therapies (PRP, exosome therapy, hyaluronic acid injections) and neuromodulation varies widely between plans. Some plans cover these services under specific diagnostic codes while others do not. We will help you understand your options.
        </p>
      </div>
    </div>
  </section>

  <!-- Payment Options -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Payment Options</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">CareCredit Financing</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Morning Star accepts CareCredit, a healthcare financing option that allows you to spread the cost of treatment over time. CareCredit offers promotional financing periods and flexible monthly payment plans. Apply online or ask our front desk for details.
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-semibold text-brand-navy mb-2">Direct Payment</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We accept cash, check, and all major credit cards for patients paying out of pocket or covering copays and deductibles. Payment is due at the time of service unless a prior arrangement has been made.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Questions About Coverage?</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        If you are unsure whether your insurance covers a specific service, our team can help. Call us at <a href="tel:6362440124" class="text-brand-blue hover:underline">(636) 244-0124</a> with your insurance information ready, and we will check your benefits on your behalf.
      </p>
      <p class="text-gray-600 leading-relaxed">
        For <a href="/new-patients/" class="text-brand-blue hover:underline">new patients</a>, we recommend verifying coverage before your first appointment. Bring your insurance card and photo ID to your visit so we can process claims promptly.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-navy text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Do Not Let Cost Stop You From Getting Relief</h2>
      <p class="text-blue-200 mb-8">
        Call <a href="tel:6362440124" class="underline hover:text-white">(636) 244-0124</a> to discuss your insurance or payment options. Morning Star in St. Peters, MO is here to help.
      </p>
      <a href="/schedule-appointment" class="px-8 py-3 bg-white text-brand-navy font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Schedule Your Evaluation
      </a>
    </div>
  </section>
</BaseLayout>
